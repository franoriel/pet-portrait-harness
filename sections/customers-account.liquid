<div class="customer-page section-padding">
  <div class="container container--mid">
    <div class="account-header">
      <div>
        <span class="eyebrow">My Account</span>
        <h1>Hi, {{ customer.first_name }}!</h1>
      </div>
      <a href="{{ routes.root_url }}account/logout" class="btn btn--outline">Sign Out</a>
    </div>

    <div class="account-grid">
      <section class="account-orders">
        <h2>Your Orders</h2>
        {%- if customer.orders.size > 0 -%}
          <div class="orders-table-wrap">
            <table class="orders-table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Total</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {%- for order in customer.orders -%}
                  <tr>
                    <td>{{ order.name }}</td>
                    <td>{{ order.created_at | date: '%b %-d, %Y' }}</td>
                    <td><span class="order-status order-status--{{ order.financial_status }}">{{ order.financial_status_label }}</span></td>
                    <td>{{ order.total_price | money }} CAD</td>
                    <td><a href="{{ order.customer_url }}" class="text-link">Details →</a></td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>
        {%- else -%}
          <div class="account-empty">
            <p class="account-empty__icon">✦</p>
            <p class="text-muted">No orders yet. Time to create your first pet portrait!</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" style="margin-top:16px;">Shop Now</a>
          </div>
        {%- endif -%}
      </section>

      <aside class="account-sidebar">
        <section class="account-details">
          <h2>Account Details</h2>
          <p>{{ customer.default_address.name }}</p>
          <p class="text-muted">{{ customer.email }}</p>
          {%- if customer.default_address -%}
            <address class="account-address" style="margin-top:12px;font-style:normal;color:var(--color-muted);font-size:0.9rem;line-height:1.6;">
              {{ customer.default_address.address1 }}<br>
              {%- if customer.default_address.address2 != blank -%}{{ customer.default_address.address2 }}<br>{%- endif -%}
              {{ customer.default_address.city }}, {{ customer.default_address.province_code }} {{ customer.default_address.zip }}<br>
              {{ customer.default_address.country }}
            </address>
          {%- endif -%}
          <a href="{{ routes.root_url }}account/addresses" class="text-link" style="display:block;margin-top:12px;font-size:0.9rem;">
            Manage addresses →
          </a>
        </section>
      </aside>
    </div>
  </div>
</div>
{% schema %}{ "name": "Customer Account" }{% endschema %}
