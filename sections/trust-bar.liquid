<div class="trust-bar" aria-label="Trust signals">
  <div class="trust-bar__track">
    {%- comment -%}Duplicate items twice for seamless infinite scroll{%- endcomment -%}
    {%- for i in (1..2) -%}
      <div class="trust-bar__set" {% if i == 2 %}aria-hidden="true"{% endif %}>
        {%- for block in section.blocks -%}
          <div class="trust-bar__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}<span class="trust-icon" aria-hidden="true">{{ block.settings.icon }}</span>{%- endif -%}
            {{ block.settings.text }}
          </div>
        {%- else -%}
          <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span> Printed in North America</div>
          <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span> Free shipping over $95</div>
          <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span> Free redos if you're not happy</div>
          <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span> Preview before you pay</div>
          <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span> 8 artistic styles</div>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "✦" },
        { "type": "text", "id": "text", "label": "Text", "default": "Independent small business" }
      ]
    }
  ],
  "presets": [{ "name": "Trust Bar" }]
}
{% endschema %}
