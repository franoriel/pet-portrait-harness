<div class="trust-bar trust-bar--glass" aria-label="Trust signals" role="region">
  <div class="trust-bar__row">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}<span class="trust-icon" aria-hidden="true">{{ block.settings.icon }}</span>{%- endif -%}
          <span class="trust-bar__text">{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span><span class="trust-bar__text">Printed in Canada</span></div>
      <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span><span class="trust-bar__text">Free shipping over $110 — Canada only</span></div>
      <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span><span class="trust-bar__text">Free redos until it's right</span></div>
      <div class="trust-bar__item"><span class="trust-icon" aria-hidden="true">✦</span><span class="trust-bar__text">Preview before you pay</span></div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "✦" },
        { "type": "text", "id": "text", "label": "Text", "default": "Independent small business" }
      ]
    }
  ],
  "presets": [{ "name": "Trust Bar" }]
}
{% endschema %}
