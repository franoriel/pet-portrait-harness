{% comment %}
  Product page — upload widget + form + variant picker + ATC
  Place inside the product template JSON as a section.
{% endcomment %}
<script type="application/json" id="ProductVariantData">
  [
    {%- for variant in product.variants -%}
      {
        "id": {{ variant.id }},
        "title": {{ variant.title | json }},
        "price": {{ variant.price }},
        "priceFormatted": {{ variant.price | money | json }},
        "available": {{ variant.available | json }},
        "options": {{ variant.options | json }},
        "imageId": {{ variant.image.id | default: 'null' }}
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
</script>
<script type="application/json" id="ProductImageData">
  [
    {%- for image in product.images limit: 8 -%}
      { "id": {{ image.id }}, "index": {{ forloop.index0 }} }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
</script>
<div class="product-layout" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title | escape }}">
  <meta itemprop="description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
  {%- if product.featured_image -%}
    <meta itemprop="image" content="{{ product.featured_image | image_url: width: 800 }}">
  {%- endif -%}

  <!-- Gallery -->
  <div class="product-gallery">
    <div class="product-gallery__track" role="list" aria-label="Product images">
      {%- for image in product.images limit: 8 -%}
        <div class="product-gallery__slide" role="listitem">
          {%- if forloop.first -%}
            {{ image | image_url: width: 800 | image_tag: loading: 'eager', alt: image.alt, widths: '400, 800', sizes: '(min-width:1024px) 50vw, 100vw' }}
          {%- else -%}
            {{ image | image_url: width: 800 | image_tag: loading: 'lazy', alt: image.alt, widths: '400, 800', sizes: '(min-width:1024px) 50vw, 100vw' }}
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="product-gallery__slide">{{ 'product-1' | placeholder_svg_tag }}</div>
      {%- endfor -%}
    </div>
    {%- if product.images.size > 1 -%}
      <div class="product-gallery__dots" aria-hidden="true">
        {%- for image in product.images limit: 8 -%}
          <span class="product-gallery__dot{% if forloop.first %} is-active{% endif %}"></span>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Product info -->
  <div class="product-info">
    <p class="eyebrow">{{ product.type | default: 'Custom Pet Portrait' }}</p>
    <h1 class="product-info__title" itemprop="name">{{ product.title }}</h1>

    <!-- Rating schema -->
    <div itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating" style="display:none">
      <meta itemprop="ratingValue" content="{{ section.settings.rating_value | default: '4.9' }}">
      <meta itemprop="reviewCount" content="{{ section.settings.review_count | default: '124' }}">
    </div>

    <div style="display:flex;align-items:center;gap:6px;margin-bottom:16px;">
      {%- render 'review-stars', rating: section.settings.rating_value, count: section.settings.review_count -%}
    </div>

    <div class="product-info__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="priceCurrency" content="CAD">
      <meta itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
      <meta itemprop="availability" content="{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">
      {{ product.price_min | money }}
      <span class="currency-label">CAD</span>
    </div>

    {%- form 'product', product, class: 'product-form' -%}
      <!-- Variant picker -->
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="variant-picker">
            <label class="variant-picker__label" for="Option-{{ option.name | handleize }}">
              {{ option.name }}
            </label>
            <div class="variant-picker__options" id="Option-{{ option.name | handleize }}">
              {%- for value in option.values -%}
                <label class="variant-option {% if option.selected_value == value %}is-selected{% endif %}">
                  <input
                    type="radio"
                    name="{{ option.name }}"
                    value="{{ value | escape }}"
                    {% if option.selected_value == value %}checked{% endif %}
                    class="visually-hidden"
                  >
                  {{ value }}
                </label>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <!-- Upload widget -->
      {%- if section.settings.show_upload -%}
        <div style="margin-bottom:8px;">
          <p class="variant-picker__label">Step 1 — Upload your pet's photo</p>
          <div class="upload-widget" role="button" tabindex="0" aria-label="Tap to upload your pet's photo">
            <input
              type="file"
              id="PetPhotoUpload"
              name="properties[Pet Photo]"
              accept="image/*"
              class="visually-hidden"
              aria-label="Upload pet photo"
            >
            <div class="upload-widget__icon" aria-hidden="true">✦</div>
            <p class="upload-widget__title">Tap to upload your pet's photo</p>
            <p class="upload-widget__sub">JPG, PNG or WebP · Max 20 MB</p>
            <div class="upload-widget__preview"><img src="" alt="Uploaded pet photo preview" loading="lazy"></div>
          </div>
        </div>

        <!-- Pet name line art property -->
        <div class="variant-picker" style="margin-bottom:20px;">
          <label class="variant-picker__label" for="PetName" style="display:flex;align-items:baseline;justify-content:space-between;">
            <span>Step 2 — Your pet's name (for the portrait)</span>
            <span id="PetNameCounter" aria-live="polite" style="font-size:0.78rem;font-weight:500;color:var(--color-muted);letter-spacing:0;text-transform:none;">0/20</span>
          </label>
          <input
            type="text"
            id="PetName"
            name="properties[Pet Name]"
            placeholder="e.g. Biscuit"
            maxlength="20"
            style="width:100%;padding:12px 14px;border:1.5px solid var(--color-border);border-radius:var(--radius-sm);font-size:0.95rem;background:var(--color-surface);color:var(--color-ink);font-family:var(--font-body);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--color-primary)'"
            onblur="this.style.borderColor='var(--color-border)'"
            oninput="var c=document.getElementById('PetNameCounter');if(c){c.textContent=this.value.length+'/20';c.style.color=this.value.length>=17?'var(--color-warning,#c78b00)':'var(--color-muted)';}"
          >
          <p style="margin:6px 0 0;font-size:0.75rem;color:var(--color-muted);">Short names print the clearest — up to 20 characters fit on the canvas.</p>
        </div>
      {%- endif -%}

      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      <button
        type="submit"
        name="add"
        class="btn btn--primary btn--full btn--large atc-btn"
        {% unless product.available %}disabled{% endunless %}
        aria-label="Add {{ product.title }} to cart"
      >
        {%- if product.available -%}
          Add to Cart — {{ product.price_min | money }} CAD
        {%- else -%}
          Sold Out
        {%- endif -%}
      </button>
    {%- endform -%}

    <!-- Trust badges -->
    <div class="trust-badges" role="list" aria-label="Trust signals">
      <div class="trust-badge" role="listitem"><span class="trust-badge__icon">✦</span> Preview before you pay</div>
      <div class="trust-badge" role="listitem"><span class="trust-badge__icon">✦</span> Ships in a few business days</div>
      <div class="trust-badge" role="listitem"><span class="trust-badge__icon">✦</span> Satisfaction guaranteed</div>
      <div class="trust-badge" role="listitem"><span class="trust-badge__icon">✦</span> Canadian business</div>
    </div>

    <!-- Product details accordions -->
    <div class="pdp-accordions" style="margin-top:20px;border-top:1px solid var(--color-border);">

      <!-- About this piece -->
      <div class="faq__item">
        <button class="faq__question" aria-expanded="false" style="font-size:1.15rem;">
          About this piece
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="faq__answer">
          <p style="margin:0 0 10px;line-height:1.7;">Your pet, reimagined as a one-of-a-kind portrait in your chosen artistic style. Each piece is generated from your photo using AI, then printed on museum-grade materials built to last.</p>
          <p style="margin:0;line-height:1.7;color:var(--color-muted);">No two portraits are alike — this is uniquely yours.</p>
        </div>
      </div>

      <!-- Materials & quality -->
      <div class="faq__item">
        <button class="faq__question" aria-expanded="false" style="font-size:1.15rem;">
          Materials &amp; quality
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="faq__answer">
          {%- if product.type == 'Canvas' or product.handle == 'canvas' -%}
            <ul style="padding-left:16px;list-style:disc;display:flex;flex-direction:column;gap:6px;line-height:1.6;">
              <li>1.25″ thick poly-cotton blend canvas</li>
              <li>Fade-resistant archival inks</li>
              <li>Hand-stretched over solid wood stretcher bars</li>
              <li>Mounting brackets included — ready to hang</li>
            </ul>
          {%- elsif product.handle == 'poster' -%}
            <ul style="padding-left:16px;list-style:disc;display:flex;flex-direction:column;gap:6px;line-height:1.6;">
              <li>Heavyweight matte paper (189 g/m²)</li>
              <li>Giclée-quality printing</li>
              <li>Vivid colours, gallery-ready finish</li>
              <li>Ships flat in a protective mailer</li>
            </ul>
          {%- else -%}
            <p style="line-height:1.7;">Premium materials, built to last.</p>
          {%- endif -%}
        </div>
      </div>

      <!-- Size guide -->
      <div class="faq__item">
        <button class="faq__question" aria-expanded="false" style="font-size:1.15rem;">
          Size guide
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="faq__answer">
          {%- if product.handle == 'canvas' -%}
            <table style="width:100%;font-size:0.85rem;border-collapse:collapse;">
              <thead><tr style="text-align:left;color:var(--color-muted);border-bottom:1px solid var(--color-border);">
                <th style="padding:8px 0;font-weight:500;">Size</th><th style="padding:8px 0;font-weight:500;">cm</th><th style="padding:8px 0;font-weight:500;">Best for</th>
              </tr></thead>
              <tbody>
                <tr style="border-bottom:1px solid var(--color-border);"><td style="padding:8px 0;">10×10″</td><td>25 × 25</td><td style="color:var(--color-muted);">Desk or shelf</td></tr>
                <tr style="border-bottom:1px solid var(--color-border);"><td style="padding:8px 0;">10×20″</td><td>25 × 51</td><td style="color:var(--color-muted);">Narrow wall space</td></tr>
                <tr style="border-bottom:1px solid var(--color-border);"><td style="padding:8px 0;">12×18″</td><td>30 × 46</td><td style="color:var(--color-muted);">Living room</td></tr>
                <tr><td style="padding:8px 0;">12×24″</td><td>30 × 61</td><td style="color:var(--color-muted);">Statement piece</td></tr>
              </tbody>
            </table>
          {%- elsif product.handle == 'poster' -%}
            <p style="line-height:1.7;">Standard poster size — fits most off-the-shelf frames.</p>
          {%- endif -%}
        </div>
      </div>

      <!-- Shipping & turnaround -->
      <div class="faq__item">
        <button class="faq__question" aria-expanded="false" style="font-size:1.15rem;">
          Shipping &amp; turnaround
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="faq__answer">
          <ul style="padding-left:16px;list-style:disc;display:flex;flex-direction:column;gap:6px;line-height:1.6;">
            <li>We aim for quick turnaround — production usually within a few business days</li>
            <li>Delivery to Canada &amp; US typically takes a few additional business days</li>
            <li>Tracking sent by email once your order ships</li>
            <li>Estimated timelines, not guarantees — actual times may vary</li>
          </ul>
        </div>
      </div>

      <!-- Our guarantee -->
      <div class="faq__item">
        <button class="faq__question" aria-expanded="false" style="font-size:1.15rem;">
          Our guarantee
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="faq__answer">
          <p style="line-height:1.7;">Preview your portrait before we print. Not in love? We'll regenerate it for free. Still not right? Full refund, no questions asked.</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Load AFTER gallery HTML so DOM is ready; runs before DOMContentLoaded handlers in theme.js -->
<script src="{{ 'pdp-portrait-inject.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Product Upload Form",
  "settings": [
    { "type": "checkbox", "id": "show_upload", "label": "Show photo upload widget", "default": true },
    { "type": "range", "id": "inventory_threshold", "label": "Show scarcity when stock below", "min": 0, "max": 20, "step": 1, "default": 5 },
    { "type": "text", "id": "rating_value", "label": "Star rating (for schema)", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review count (for schema)", "default": "124" }
  ]
}
{% endschema %}
