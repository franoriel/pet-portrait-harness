<div class="customer-page section-padding">
  <div class="container" style="max-width:480px;">
    <div class="customer-card">
      <div class="customer-card__header text-center">
        <h1>Reset your password</h1>
        <p class="text-muted">Enter your email and we'll send you a reset link.</p>
      </div>
      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <div class="form-success" role="status">
            <span style="font-size:1.5rem;">✦</span>
            <p>We've sent you a reset link — check your inbox.</p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="form-errors" role="alert">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          <div class="form-field">
            <label class="form-label" for="RecoverEmail">Email</label>
            <input type="email" id="RecoverEmail" name="email" autocomplete="email" autocapitalize="off" class="form-input" required>
          </div>
          <button type="submit" class="btn btn--primary btn--full btn--large">Send Reset Link</button>
        {%- endif -%}
      {%- endform -%}
      <p class="customer-card__footer text-muted">
        <a href="{{ routes.root_url }}account/login" style="color:var(--color-primary);">← Back to sign in</a>
      </p>
    </div>
  </div>
</div>
{% schema %}{ "name": "Reset Password" }{% endschema %}
