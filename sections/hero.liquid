<section class="hero" aria-label="Hero">
  <!-- Full-bleed hero image -->
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{- section.settings.image | image_url: width: 1600 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '375, 750, 1100, 1600',
        alt: section.settings.image.alt | default: 'Pet portrait example'
      -}}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
    {%- endif -%}
  </div>

  <!-- Content overlay — bottom-aligned -->
  <div class="hero__content container">
    <h1 class="hero__title" data-reveal>{{ section.settings.heading | default: 'They deserve a spot on the wall.' }}</h1>
    <p class="hero__sub" data-reveal>{{ section.settings.subheading | default: 'Upload a photo. Choose from 9 artistic styles. Get a stunning portrait on canvas, shipped to your door.' }}</p>

    <div class="hero__cta-group" data-reveal>
      <a href="{{ section.settings.cta_url | default: '/pages/create' }}" class="btn btn--primary btn--large">
        {{ section.settings.cta_label | default: 'Create My Portrait' }}
      </a>
      {%- if section.settings.secondary_cta_label != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="btn btn--outline btn--large" style="border-color:rgba(255,255,255,0.6);color:#fff;">
          {{ section.settings.secondary_cta_label }}
        </a>
      {%- endif -%}
    </div>

    <p class="hero__reassurance" data-reveal>{{ section.settings.reassurance | default: '✓ Preview before you pay · ✓ Free shipping over $85 · ✓ Made in Canada' }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "They deserve a spot on the wall." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Upload a photo. Choose from 9 artistic styles. Get a stunning portrait on canvas, shipped to your door." },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating badge", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 from 124+ pet parents" },
    { "type": "text", "id": "cta_label", "label": "Primary CTA label", "default": "Create My Portrait" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label (optional)" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "reassurance", "label": "Reassurance text below CTAs", "default": "✓ Preview before you pay · ✓ Free shipping over $85 · ✓ Made in Canada" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
