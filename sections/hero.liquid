<section class="hero" aria-label="Hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{- section.settings.image | image_url: width: 1600 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '375, 750, 1100, 1600',
        alt: section.settings.image.alt | default: shop.name
      -}}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__content container">
<h1 class="hero__title" data-reveal>{{ section.settings.heading | default: 'Immortalize your best friend.' }}</h1>
    <p class="hero__sub" data-reveal>{{ section.settings.subheading | default: 'Turn everyday photos into stunning pet portraits. Choose from 9 artistic styles. A modern tribute to unconditional love.' }}</p>

    <div class="hero__cta-group" data-reveal>
      <a href="{{ section.settings.cta_url | default: '/pages/create' }}" class="btn btn--primary btn--large">
        {{ section.settings.cta_label | default: 'BEGIN THE PROCESS' }}
      </a>
      {%- if section.settings.secondary_cta_label != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="btn btn--outline btn--large" style="border-color:rgba(255,255,255,0.6);color:#fff;">
          {{ section.settings.secondary_cta_label }}
        </a>
      {%- endif -%}
    </div>
    <p class="hero__reassurance" style="margin-top:14px;">{{ section.settings.reassurance | default: 'See it before you buy. Ships to Canada and the US.' }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "They deserve a spot on the wall." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Upload a photo of your pet. Choose from 9 artistic styles. Get a stunning portrait printed on canvas or paper, shipped to your door." },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating badge", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 stars from 2,000+ pet parents" },
    { "type": "text", "id": "cta_label", "label": "Primary CTA label", "default": "Create My Portrait" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label (optional)" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "reassurance", "label": "Reassurance text below CTAs", "default": "See it before you buy · Made and shipped in North America" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
