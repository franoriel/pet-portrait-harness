{%- assign parallax_on = section.settings.enable_parallax -%}
{%- assign parallax_strength = section.settings.parallax_strength | default: 0.35 -%}
<section class="hero{% if parallax_on %} hero--parallax{% endif %}"
         aria-label="Hero"
         {% if parallax_on %}data-parallax="true" data-parallax-strength="{{ parallax_strength }}"{% endif %}>
  <!-- Full-bleed hero image -->
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{- section.settings.image | image_url: width: 1600 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '375, 750, 1100, 1600',
        alt: section.settings.image.alt | default: 'Pet portrait example'
      -}}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
    {%- endif -%}
  </div>

  <!-- Content overlay — bottom-aligned -->
  <div class="hero__content container">
    <h1 class="hero__title" data-reveal>{{ section.settings.heading | default: 'They deserve a spot on the wall.' }}</h1>
    <p class="hero__sub" data-reveal>{{ section.settings.subheading | default: 'Upload a photo. Choose from 8 artistic styles. Get a stunning portrait on canvas, shipped to your door.' }}</p>

    <div class="hero__cta-group" data-reveal>
      <a href="{{ section.settings.cta_url | default: '/pages/create' }}" class="btn btn--canvas-frame btn--large">
        <span class="btn__canvas-inner">
          {{ section.settings.cta_label | default: 'Create My Portrait' }}
          <svg class="btn__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
      {%- if section.settings.secondary_cta_label != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="btn btn--outline btn--large" style="border-color:rgba(255,255,255,0.6);color:#fff;">
          {{ section.settings.secondary_cta_label }}
        </a>
      {%- endif -%}
    </div>

    <p class="hero__reassurance" data-reveal>{{ section.settings.reassurance | default: '✓ Preview before you pay · ✓ Free shipping over $95 · ✓ Ships within Canada only' }}</p>
  </div>
</section>

{%- if parallax_on -%}
<script>
  (function () {
    var hero = document.querySelector('.hero[data-parallax="true"]');
    if (!hero) return;
    if (window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var img = hero.querySelector('.hero__media img, .hero__media svg');
    if (!img) return;
    var strength = parseFloat(hero.dataset.parallaxStrength) || 0.35;
    var visible = true, ticking = false;
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) { visible = entries[0].isIntersecting; }, { threshold: 0 });
      io.observe(hero);
    }
    function update() {
      ticking = false;
      if (!visible) return;
      var offset = -hero.getBoundingClientRect().top * strength;
      img.style.transform = 'translate3d(0,' + offset + 'px,0) scale(1.18)';
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "checkbox", "id": "enable_parallax", "label": "Enable parallax effect", "default": true },
    { "type": "range", "id": "parallax_strength", "label": "Parallax strength", "min": 0.1, "max": 0.6, "step": 0.1, "default": 0.3 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "They deserve a spot on the wall." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Upload a photo. Choose from 8 artistic styles. Get a stunning portrait on canvas, shipped to your door." },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating badge", "default": false },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "Rating text" },
    { "type": "text", "id": "cta_label", "label": "Primary CTA label", "default": "Create My Portrait" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label (optional)" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "reassurance", "label": "Reassurance text below CTAs", "default": "✓ Preview before you pay · ✓ Free shipping over $95 · ✓ Ships within Canada only" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
