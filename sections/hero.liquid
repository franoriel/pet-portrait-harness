<section class="hero" aria-label="Hero">
  <div class="hero__split">
    <!-- Left: Text content -->
    <div class="hero__text">
      {%- if section.settings.show_rating -%}
        <div class="hero__rating" data-reveal>
          <span aria-hidden="true" style="color:#D4A84B;letter-spacing:1px;">★★★★★</span>
          <span>{{ section.settings.rating_text | default: '4.9 from 124+ pet parents' }}</span>
        </div>
      {%- endif -%}

      <h1 class="hero__title" data-reveal>{{ section.settings.heading | default: 'They deserve a spot on the wall.' }}</h1>
      <p class="hero__sub" data-reveal>{{ section.settings.subheading | default: 'Upload a photo of your pet. Choose from 9 artistic styles. Get a stunning portrait printed on canvas or paper, shipped to your door.' }}</p>

      <div class="hero__cta-group" data-reveal>
        <a href="{{ section.settings.cta_url | default: '/pages/create' }}" class="btn btn--primary btn--large">
          {{ section.settings.cta_label | default: 'Create My Portrait' }}
        </a>
        {%- if section.settings.secondary_cta_label != blank -%}
          <a href="{{ section.settings.secondary_cta_url }}" class="btn btn--outline btn--large">
            {{ section.settings.secondary_cta_label }}
          </a>
        {%- endif -%}
      </div>

      <p class="hero__reassurance" data-reveal>{{ section.settings.reassurance | default: '✓ Preview before you pay · ✓ Free shipping over $75 · ✓ Made in Canada' }}</p>
    </div>

    <!-- Right: Hero image -->
    <div class="hero__media" data-reveal>
      {%- if section.settings.image != blank -%}
        {{- section.settings.image | image_url: width: 1200 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '(min-width:768px) 50vw, 100vw',
          widths: '375, 600, 800, 1200',
          alt: section.settings.image.alt | default: 'Pet portrait example'
        -}}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image (right side)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "They deserve a spot on the wall." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Upload a photo of your pet. Choose from 9 artistic styles. Get a stunning portrait printed on canvas or paper, shipped to your door." },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating badge", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 from 124+ pet parents" },
    { "type": "text", "id": "cta_label", "label": "Primary CTA label", "default": "Create My Portrait" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label (optional)" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "reassurance", "label": "Reassurance text below CTAs", "default": "✓ Preview before you pay · ✓ Free shipping over $75 · ✓ Made in Canada" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
