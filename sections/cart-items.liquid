<style>
  /* Priority-order tooltip — shown on hover, focus, and mobile tap */
  .priority-tooltip {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-border);
    color: var(--color-ink);
    font-size:var(--text-xs);
    font-weight: 700;
    cursor: help;
    outline: none;
    user-select: none;
    transition: background 0.15s ease;
  }
  .priority-tooltip:hover,
  .priority-tooltip:focus-visible,
  .priority-tooltip.is-open {
    background: var(--color-ink);
    color: #fff;
  }
  .priority-tooltip:focus-visible { box-shadow: 0 0 0 2px var(--color-primary, #4338CA); }
  .priority-tooltip__bubble {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    width: max-content;
    max-width: 260px;
    background: var(--color-ink);
    color: #fff;
    padding: 10px 12px;
    border-radius: 8px;
    font-size:var(--text-xs);
    line-height: 1.5;
    font-weight: 400;
    text-align: left;
    white-space: normal;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
    z-index: 50;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
  }
  .priority-tooltip__bubble::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--color-ink);
  }
  .priority-tooltip:hover .priority-tooltip__bubble,
  .priority-tooltip:focus-visible .priority-tooltip__bubble,
  .priority-tooltip.is-open .priority-tooltip__bubble {
    opacity: 1;
  }
  /* Shift left near the right edge of narrow viewports */
  @media (max-width: 480px) {
    .priority-tooltip__bubble { max-width: 220px; }
  }

  /* Newsletter recapture modal — fires on cart-page checkout click if
     pf_newsletter_status === 'skipped'. */
  .newsletter-recapture-backdrop {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(20, 17, 14, 0.55);
    backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
    display: flex; align-items: center; justify-content: center;
    padding: 20px;
    animation: nl-recapture-fade-in 0.2s ease-out;
  }
  .newsletter-recapture-backdrop[hidden] { display: none; }
  .newsletter-recapture-modal {
    background: #fff; border-radius: var(--radius-card);
    padding: 32px 28px 24px; max-width: 420px; width: 100%;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    animation: nl-recapture-pop 0.25s cubic-bezier(.2,1.2,.4,1);
    text-align: center; font-family: var(--font-body);
  }
  .newsletter-recapture-modal h3 {
    font-family: var(--font-heading); font-size:var(--text-lg);
    margin: 0 0 10px; color: var(--color-brand, var(--color-ink));
    line-height: 1.2;
  }
  .newsletter-recapture-modal > p {
    font-size:var(--text-sm); color: var(--color-muted);
    margin: 0 0 20px; line-height: 1.5;
  }
  .newsletter-recapture-modal form {
    display: flex; flex-direction: column; gap: 10px; text-align: left;
  }
  .newsletter-recapture-row {
    display: flex; gap: 8px;
  }
  .newsletter-recapture-row input { flex: 1; }
  .newsletter-recapture-modal input[type="email"],
  .newsletter-recapture-modal input[type="text"],
  .newsletter-recapture-modal input[type="tel"] {
    padding: 12px 14px; font-size:var(--text-base);
    border: 1px solid var(--color-border); border-radius: 10px;
    font-family: var(--font-body); background: #fff;
    color: var(--color-ink); width: 100%; box-sizing: border-box;
    min-height: 44px;
  }
  .newsletter-recapture-modal input:focus {
    outline: 2px solid var(--color-primary, #4338CA); outline-offset: 1px;
  }
  .newsletter-recapture-sms {
    display: flex; align-items: flex-start; gap: 10px;
    font-size:var(--text-xs); color: var(--color-ink); line-height: 1.5;
    cursor: pointer; margin-top: 4px;
  }
  .newsletter-recapture-sms input[type="checkbox"] {
    margin-top: 3px; flex-shrink: 0; width: 16px; height: 16px;
    accent-color: var(--color-primary, var(--color-accent));
  }
  .newsletter-recapture-sms a {
    color: var(--color-accent, var(--color-primary));
    text-decoration: underline;
  }
  .newsletter-recapture-error {
    color: var(--color-warning, #B45309); font-size:var(--text-xs); margin: 0;
  }
  .newsletter-recapture-skip {
    background: none; border: none; cursor: pointer;
    color: var(--color-muted); font-family: var(--font-body);
    font-size:var(--text-sm); padding: 8px 12px; margin-top: 14px;
    text-decoration: underline; text-underline-offset: 3px;
  }
  .newsletter-recapture-skip:hover { color: var(--color-ink); }
  @keyframes nl-recapture-fade-in {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes nl-recapture-pop {
    from { opacity: 0; transform: scale(0.94) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>

<div class="cart-page">
  <div class="container container--mid">
    {%- render 'breadcrumbs' -%}
    <h1 class="cart-page__title">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      <div class="cart-page__layout">
        <div class="cart-page__items">
          {%- for item in cart.items -%}
            {%- assign portrait_url = nil -%}
            {%- assign no_name_url = nil -%}
            {%- assign show_name = 'Yes' -%}
            {%- assign pet_name_val = '' -%}
            {%- assign style_val = '' -%}
            {%- assign job_id_val = '' -%}
            {%- for property in item.properties -%}
              {%- if property.first == '_Portrait URL' and property.last != blank -%}{%- assign portrait_url = property.last -%}{%- endif -%}
              {%- if property.first == '_No Name URL' and property.last != blank -%}{%- assign no_name_url = property.last -%}{%- endif -%}
              {%- if property.first == '_Show Name' -%}{%- assign show_name = property.last -%}{%- endif -%}
              {%- if property.first == 'Pet Name' -%}{%- assign pet_name_val = property.last -%}{%- endif -%}
              {%- if property.first == '_Style' -%}{%- assign style_val = property.last -%}{%- endif -%}
              {%- if property.first == '_Job ID' -%}{%- assign job_id_val = property.last -%}{%- endif -%}
            {%- endfor -%}
            <div class="cart-page__item"
                 data-cart-item="{{ item.key }}"
                 data-show-name="{{ show_name }}"
                 data-pet-name="{{ pet_name_val | escape }}"
                 data-style="{{ style_val | escape }}"
                 data-job-id="{{ job_id_val | escape }}"
                 data-portrait-url="{{ portrait_url | default: '' | escape }}"
                 data-no-name-url="{{ no_name_url | default: '' | escape }}">
              <div class="cart-page__item-img">
                {%- if portrait_url -%}
                  <img src="{{ portrait_url }}" alt="{{ item.title }}" loading="lazy" class="cart-page__portrait-preview" style="width:100%;border-radius:8px;object-fit:cover;">
                {%- elsif item.image -%}
                  {{- item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title -}}
                {%- endif -%}
              </div>
              <div class="cart-page__item-info">
                <div class="cart-page__item-header">
                  <div>
                    <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p class="cart-page__item-variant text-muted">{{ item.variant.title }}</p>
                    {%- endunless -%}
                    {%- comment -%}
                      Style is stored as the hidden `_Style` slug on every line item
                      (see pdp-portrait-inject.js). Translate to a friendly label so
                      the customer sees which style they picked while reviewing
                      their cart. Falls back to the slug if a future style isn't
                      mapped yet so we never show a blank row.
                    {%- endcomment -%}
                    {%- if style_val != blank -%}
                      {%- assign style_label = style_val -%}
                      {%- case style_val -%}
                        {%- when 'soft-watercolour'    -%}{%- assign style_label = 'Soft Watercolour' -%}
                        {%- when 'minimal-line-art'    -%}{%- assign style_label = 'Minimal Line Art' -%}
                        {%- when 'modern-shape-art'    -%}{%- assign style_label = 'Modern' -%}
                        {%- when 'neon-pop-art'        -%}{%- assign style_label = 'Neon Pop Art' -%}
                        {%- when 'renaissance-royalty' -%}{%- assign style_label = 'Renaissance Royalty' -%}
                        {%- when 'bold-graphic-poster' -%}{%- assign style_label = 'Bold Graphic Poster' -%}
                        {%- when 'aura-gradient'       -%}{%- assign style_label = 'Aura Gradient' -%}
                        {%- when 'charcoal'            -%}{%- assign style_label = 'Charcoal' -%}
                      {%- endcase -%}
                      <p class="cart-page__item-prop text-muted" style="font-size:var(--text-sm);margin-top:4px;">
                        Style: <span style="color:var(--color-ink);font-weight:600;">{{ style_label }}</span>
                      </p>
                    {%- endif -%}
                    {%- for property in item.properties -%}
                      {%- unless property.last == blank -%}
                        {%- assign prop_first_char = property.first | slice: 0 -%}
                        {%- unless prop_first_char == '_' -%}
                          <p class="cart-page__item-prop text-muted" style="font-size:var(--text-sm);">
                            {{ property.first }}: {{ property.last }}
                          </p>
                        {%- endunless -%}
                      {%- endunless -%}
                    {%- endfor -%}
                  </div>
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0"
                     class="cart-page__remove" aria-label="Remove {{ item.title | escape }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </a>
                </div>
                {%- if pet_name_val != blank -%}
                <div class="cart-page__name-toggle" style="display:flex;align-items:center;gap:8px;margin:10px 0;font-size:var(--text-sm);">
                  <span style="color:var(--color-muted);">Name on portrait:</span>
                  <button type="button" class="cart-name-btn" data-name-value="Yes"
                          aria-pressed="{% if show_name == 'Yes' %}true{% else %}false{% endif %}"
                          style="padding:4px 12px;border-radius:14px;border:1px solid var(--color-border);cursor:pointer;font-size:var(--text-sm);font-weight:500;background:{% if show_name == 'Yes' %}var(--color-ink);color:#fff;{% else %}transparent;color:var(--color-ink);{% endif %}">Yes</button>
                  <button type="button" class="cart-name-btn" data-name-value="No"
                          aria-pressed="{% if show_name == 'No' %}true{% else %}false{% endif %}"
                          style="padding:4px 12px;border-radius:14px;border:1px solid var(--color-border);cursor:pointer;font-size:var(--text-sm);font-weight:500;background:{% if show_name == 'No' %}var(--color-ink);color:#fff;{% else %}transparent;color:var(--color-ink);{% endif %}">No</button>
                  <span class="cart-name-status" style="color:var(--color-muted);font-size:var(--text-xs);display:none;"></span>
                </div>
                {%- endif -%}
                <div class="cart-page__item-footer">
                  <div class="cart-qty">
                    <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="cart-qty__btn" aria-label="Decrease quantity">−</a>
                    <span class="cart-qty__num">{{ item.quantity }}</span>
                    <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="cart-qty__btn" aria-label="Increase quantity">+</a>
                  </div>
                  <span class="cart-page__item-price">{{ item.final_line_price | money }} CAD</span>
                </div>
              </div>
            </div>
          {%- endfor -%}

          <!-- Add another portrait CTA -->
          <a href="/pages/create" class="cart-add-another" style="display:flex;align-items:center;justify-content:center;gap:10px;padding:18px;margin-top:12px;border:1.5px solid var(--color-ink);border-radius:var(--radius-card);background:var(--color-surface);text-decoration:none;color:var(--color-ink);font-family:var(--font-body);font-size:var(--text-base);font-weight:600;transition:all 0.2s;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m-8-8h16"/>
            </svg>
            <span>Create another portrait for your family</span>
          </a>
        </div>

        <aside class="cart-page__summary">
          <div class="cart-summary">
            <h2 class="cart-summary__title">Order Summary</h2>
            <div class="cart-summary__row">
              <span>Subtotal ({{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %})</span>
              <span>{{ cart.total_price | money }} CAD</span>
            </div>
            {%- if cart.total_discounts > 0 -%}
              <div class="cart-summary__row cart-summary__row--discount">
                <span>Discounts</span>
                <span>−{{ cart.total_discounts | money }}</span>
              </div>
            {%- endif -%}

            {%- comment -%}
              Free shipping threshold tracker
              cart.total_price is in cents — $95 CAD = 9500 cents
            {%- endcomment -%}
            {%- assign free_ship_cents = 9500 -%}
            {%- assign remaining_cents = free_ship_cents | minus: cart.total_price -%}
            {%- if remaining_cents > 0 -%}
              {%- assign progress_pct = cart.total_price | times: 100.0 | divided_by: free_ship_cents -%}
              <div class="free-ship-tracker" style="margin:14px 0;padding:14px;background:var(--color-surface);border-radius:var(--radius-card);border:1px solid var(--color-border);">
                <div style="display:flex;align-items:center;gap:8px;font-size:var(--text-base);color:var(--color-ink);margin-bottom:10px;line-height:1.4;">
                  <span>You're <strong style="font-weight:700;color:var(--color-primary);">{{ remaining_cents | money }}</strong> away from free shipping</span>
                </div>
                <div style="height:6px;background:var(--color-border);border-radius:99px;overflow:hidden;">
                  <div style="height:100%;width:{{ progress_pct }}%;background:linear-gradient(90deg,var(--color-primary),var(--color-accent));border-radius:99px;transition:width 0.5s ease;"></div>
                </div>
              </div>
            {%- else -%}
              <div class="free-ship-tracker free-ship-tracker--achieved" style="margin:14px 0;padding:14px;background:#E8F5E9;border-radius:var(--radius-card);border:1px solid #81C784;">
                <div style="display:flex;align-items:center;gap:8px;font-size:var(--text-sm);color:#1B5E20;font-weight:600;line-height:1.4;">
                  <span>You've unlocked <strong>free shipping</strong>.</span>
                </div>
              </div>
            {%- endif -%}

            {%- comment -%}
              Priority Order upsell — markup removed pending reliable
              2-business-day fulfillment. The JS handler further down
              safely no-ops when [data-priority-upsell] is absent, so
              restoring this is: paste the toggle markup back and ship.
            {%- endcomment -%}

            {%- comment -%}
              Digital Files upsell — adds the digital-files product as a
              line item so customers can download high-res files sized
              for Instagram and Facebook sharing after checkout.
            {%- endcomment -%}
            {%- assign digital_in_cart = false -%}
            {%- assign digital_line_key = '' -%}
            {%- for item in cart.items -%}
              {%- if item.product.handle == 'digital-files' -%}
                {%- assign digital_in_cart = true -%}
                {%- assign digital_line_key = item.key -%}
              {%- endif -%}
            {%- endfor -%}

            <div
              class="digital-files-upsell"
              data-digital-files-upsell
              data-in-cart="{{ digital_in_cart }}"
              data-line-key="{{ digital_line_key }}"
              style="margin:12px 0;padding:14px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-card);"
            >
              <label style="display:flex;align-items:flex-start;gap:12px;cursor:pointer;font-family:var(--font-body);">
                <input
                  type="checkbox"
                  id="DigitalFilesUpsellToggle"
                  {% if digital_in_cart %}checked{% endif %}
                  style="width:18px;height:18px;margin-top:2px;accent-color:var(--color-primary);flex-shrink:0;"
                >
                <span style="flex:1;line-height:1.45;">
                  <span style="display:flex;align-items:center;gap:6px;font-size:var(--text-base);font-weight:600;color:var(--color-ink);">
                    Digital Files for Sharing
                    <span
                      data-digital-files-price
                      style="margin-left:auto;font-weight:600;color:var(--color-primary);font-size:var(--text-sm);"
                    ></span>
                  </span>
                  <span style="display:block;font-size:var(--text-sm);color:var(--color-muted);margin-top:3px;">
                    Get high-res files sized for Instagram &amp; Facebook — Story (9:16), Square (1:1), Portrait (4:5), plus the full-resolution original.
                  </span>
                  <span
                    data-digital-files-status
                    role="status"
                    aria-live="polite"
                    style="display:none;font-size:var(--text-xs);color:var(--color-muted);margin-top:4px;"
                  ></span>
                </span>
              </label>
            </div>

            {%- comment -%}
              Magnet upsell — offers a matching fridge magnet using the
              same portrait already in the cart. Only surfaces when at
              least one portrait line item exists (i.e. a line item with
              a _Portrait URL property). When toggled on, the magnet is
              added with the portrait's properties copied over so
              fulfillment knows which design to print on the magnet.
            {%- endcomment -%}
            {%- assign magnet_in_cart = false -%}
            {%- assign magnet_line_key = '' -%}
            {%- assign magnet_current_variant_id = 0 -%}
            {%- assign source_portrait_url = '' -%}
            {%- assign source_print_url = '' -%}
            {%- assign source_no_name_url = '' -%}
            {%- assign source_pet_name = '' -%}
            {%- assign source_style = '' -%}
            {%- assign source_job_id = '' -%}
            {%- assign source_show_name = 'Yes' -%}
            {%- for item in cart.items -%}
              {%- if item.product.handle == 'magnet' -%}
                {%- assign magnet_in_cart = true -%}
                {%- assign magnet_line_key = item.key -%}
                {%- assign magnet_current_variant_id = item.variant.id -%}
              {%- endif -%}
              {%- if source_portrait_url == '' -%}
                {%- for property in item.properties -%}
                  {%- if property.first == '_Portrait URL' and property.last != blank -%}
                    {%- assign source_portrait_url = property.last -%}
                  {%- endif -%}
                  {%- if property.first == '_Print File URL' and property.last != blank -%}
                    {%- assign source_print_url = property.last -%}
                  {%- endif -%}
                  {%- if property.first == '_No Name URL' and property.last != blank -%}
                    {%- assign source_no_name_url = property.last -%}
                  {%- endif -%}
                  {%- if property.first == 'Pet Name' -%}
                    {%- assign source_pet_name = property.last -%}
                  {%- endif -%}
                  {%- if property.first == '_Style' -%}
                    {%- assign source_style = property.last -%}
                  {%- endif -%}
                  {%- if property.first == '_Job ID' -%}
                    {%- assign source_job_id = property.last -%}
                  {%- endif -%}
                  {%- if property.first == '_Show Name' -%}
                    {%- assign source_show_name = property.last -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if source_portrait_url != '' -%}
            <div
              class="magnet-upsell"
              data-magnet-upsell
              data-in-cart="{{ magnet_in_cart }}"
              data-line-key="{{ magnet_line_key }}"
              data-current-variant-id="{{ magnet_current_variant_id }}"
              data-portrait-url="{{ source_portrait_url | escape }}"
              data-print-url="{{ source_print_url | escape }}"
              data-no-name-url="{{ source_no_name_url | escape }}"
              data-pet-name="{{ source_pet_name | escape }}"
              data-style="{{ source_style | escape }}"
              data-job-id="{{ source_job_id | escape }}"
              data-show-name="{{ source_show_name | escape }}"
              style="margin:12px 0;padding:14px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-card);"
            >
              <label style="display:flex;align-items:flex-start;gap:12px;cursor:pointer;font-family:var(--font-body);">
                <input
                  type="checkbox"
                  id="MagnetUpsellToggle"
                  {% if magnet_in_cart %}checked{% endif %}
                  style="width:18px;height:18px;margin-top:2px;accent-color:var(--color-primary);flex-shrink:0;"
                >
                <span style="flex:1;line-height:1.45;display:flex;gap:10px;align-items:center;">
                  <img
                    src="{{ source_portrait_url }}"
                    alt="{{ source_pet_name | default: 'Pet portrait' | escape }} preview"
                    loading="lazy"
                    style="width:48px;height:48px;object-fit:cover;border-radius:8px;flex-shrink:0;border:1px solid var(--color-border);"
                  >
                  <span style="flex:1;min-width:0;">
                    <span style="display:flex;flex-wrap:wrap;align-items:center;gap:6px;font-size:var(--text-base);font-weight:600;color:var(--color-ink);">
                      <span style="flex:1;min-width:0;">Matching fridge magnet{%- if source_pet_name != '' %} of {{ source_pet_name }}{%- endif -%}</span>
                      <span
                        data-magnet-price
                        style="margin-left:auto;font-weight:600;color:var(--color-primary);font-size:var(--text-sm);white-space:nowrap;"
                      ></span>
                    </span>
                    <span style="display:block;font-size:var(--text-sm);color:var(--color-muted);margin-top:3px;">
                      Same portrait, printed on a flexible fridge magnet. Ships with your order.
                    </span>
                    <span
                      data-magnet-status
                      role="status"
                      aria-live="polite"
                      style="display:none;font-size:var(--text-xs);color:var(--color-muted);margin-top:4px;"
                    ></span>
                  </span>
                </span>
              </label>

              {%- comment -%}
                Size picker — populated at runtime from /products/magnet.js
                so prices stay in sync with Shopify without a template
                redeploy. Hidden until the variants load.
              {%- endcomment -%}
              <div
                data-magnet-sizes
                role="radiogroup"
                aria-label="Magnet size"
                style="display:none;flex-wrap:wrap;gap:8px;margin-top:12px;padding-left:30px;"
              ></div>
            </div>
            {%- endif -%}

            {%- comment -%}
              Priority order upsell (FAB framing — Feature: priority lane;
              Advantage: same-day QA + immediate fulfillment handoff;
              Benefit: 1–2 days sooner).

              Adds the "priority-order" Shopify product as a paid line
              item (variant_id resolved at runtime via Liquid so price
              stays in sync with Shopify admin) AND sets a redundant
              `Priority order: Yes` cart attribute so the QA/ops team
              can spot it in the order admin without scanning line items.

              The product handle is hardcoded — change it here if you
              ever rename the product slug in admin.
            {%- endcomment -%}
            {%- assign priority_product = all_products['priority-order'] -%}
            {%- assign priority_variant = priority_product.variants.first -%}
            {%- assign priority_in_cart = false -%}
            {%- assign priority_line_key = '' -%}
            {%- if priority_variant -%}
              {%- for item in cart.items -%}
                {%- if item.variant_id == priority_variant.id -%}
                  {%- assign priority_in_cart = true -%}
                  {%- assign priority_line_key = item.key -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
            {%- if priority_variant -%}
            <div
              class="cart-summary__priority"
              data-priority-toggle
              data-variant-id="{{ priority_variant.id }}"
              data-line-key="{{ priority_line_key }}"
              data-in-cart="{{ priority_in_cart }}"
              style="margin:12px 0;padding:14px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-card);"
            >
              <label style="display:flex;align-items:flex-start;gap:12px;cursor:pointer;font-family:var(--font-body);">
                <input
                  type="checkbox"
                  id="PriorityOrderToggle"
                  data-priority-checkbox
                  {% if priority_in_cart %}checked{% endif %}
                  style="width:18px;height:18px;margin-top:2px;accent-color:var(--color-primary);flex-shrink:0;"
                >
                <span style="flex:1;line-height:1.45;">
                  <span style="display:flex;align-items:center;gap:6px;font-size:var(--text-base);font-weight:600;color:var(--color-ink);flex-wrap:wrap;">
                    Priority order
                    <span
                      class="priority-tooltip"
                      tabindex="0"
                      role="button"
                      aria-label="What is priority order?"
                      aria-describedby="PriorityOrderTip"
                    >
                      ?
                      <span id="PriorityOrderTip" role="tooltip" class="priority-tooltip__bubble">
                        Our QA team processes priority orders the same day and hands them straight to fulfillment — usually 1–2 days faster on production. (Carrier shipping is unchanged: 3–5 business days.)
                      </span>
                    </span>
                    <span style="margin-left:auto;font-weight:600;color:var(--color-primary);font-size:var(--text-sm);">
                      +{{ priority_variant.price | money }}
                    </span>
                  </span>
                  <span style="display:block;font-size:var(--text-sm);color:var(--color-muted);margin-top:3px;">
                    Skip the QA queue — get it 1–2 days sooner.
                  </span>
                  <span
                    data-priority-status
                    role="status"
                    aria-live="polite"
                    style="display:block;font-size:var(--text-xs);color:var(--color-muted);margin-top:6px;min-height:1em;"
                  ></span>
                </span>
              </label>
            </div>
            {%- endif -%}

            {%- comment -%}
              Shipping estimator — user enters a postal code, we call
              Shopify's /cart/shipping_rates.json (same carrier rates
              the checkout uses). It's an estimate only — discounts and
              final addresses may change the amount at checkout.
            {%- endcomment -%}
            <div class="cart-summary__estimator" data-shipping-estimator style="margin:14px 0;padding:14px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-card);">
              <label for="ShippingEstPostal" style="display:block;font-family:var(--font-body);font-size:var(--text-sm);font-weight:600;color:var(--color-ink);margin-bottom:8px;">
                Estimate shipping
              </label>
              <div style="display:flex;gap:8px;">
                <input
                  id="ShippingEstPostal"
                  type="text"
                  inputmode="text"
                  autocomplete="postal-code"
                  placeholder="Postal code (e.g. K1A 0B1)"
                  aria-describedby="ShippingEstNote"
                  style="flex:1;min-width:0;padding:9px 12px;border:1px solid var(--color-border);border-radius:8px;font-family:var(--font-body);font-size:var(--text-sm);background:#fff;color:var(--color-ink);"
                >
                <button
                  type="button"
                  data-shipping-estimate-btn
                  style="padding:10px 18px;border:1px solid var(--color-ink);background:var(--color-ink);color:#fff;border-radius:8px;font-family:var(--font-body);font-size:var(--text-base);font-weight:600;cursor:pointer;white-space:nowrap;min-height:44px;"
                >
                  Get Estimate
                </button>
              </div>
              <div
                data-shipping-result
                role="status"
                aria-live="polite"
                style="display:none;margin-top:10px;font-size:var(--text-sm);line-height:1.45;"
              ></div>
              <p id="ShippingEstNote" style="margin:10px 0 0;font-size:var(--text-sm);color:var(--color-muted);line-height:1.45;">
                We currently ship within Canada only. This is an estimate for your reference — final shipping is calculated at checkout and may be different.
              </p>
            </div>

            <a href="/checkout" data-checkout-btn class="btn btn--primary btn--full btn--large" style="margin-bottom:10px;">
              Checkout → <span style="font-size:var(--text-sm);opacity:0.85;">{{ cart.total_price | money }} CAD</span>
            </a>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline btn--full">
              Continue Shopping
            </a>
            <div class="cart-summary__trust">
              <span>✦ Secure checkout</span>
              <span>✦ Independent small business</span>
              <span>✦ Satisfaction guaranteed</span>
            </div>
          </div>
        </aside>
      </div>

      {%- comment -%}
        Newsletter recapture modal — only fires if the customer skipped the
        10%-off popup on the create page (pf_newsletter_status === 'skipped'
        in localStorage). Intercepts the checkout button click, asks if
        they're sure, and either re-runs the signup flow with the new email
        + applies /discount/PETFAM2026 OR proceeds to checkout untouched.
      {%- endcomment -%}
      <div
        id="newsletter-recapture-backdrop"
        class="newsletter-recapture-backdrop"
        hidden
        role="dialog"
        aria-modal="true"
        aria-labelledby="newsletter-recapture-title"
      >
        <div class="newsletter-recapture-modal">
          <h3 id="newsletter-recapture-title">Hold up — your dog won't be impressed</h3>
          <p>You skipped 10% off. Sure you want to leave money on the table when your pet's looking?</p>
          <form id="newsletter-recapture-form" novalidate>
            <div class="newsletter-recapture-row">
              <input
                type="text" name="firstName" required
                placeholder="First name" autocomplete="given-name"
                aria-label="First name"
              >
              <input
                type="text" name="lastName" required
                placeholder="Last name" autocomplete="family-name"
                aria-label="Last name"
              >
            </div>
            <input
              type="email" name="email" required
              placeholder="you@example.com" autocomplete="email"
              aria-label="Email address"
            >
            <input
              type="tel" name="phone"
              placeholder="Phone (optional, for SMS)"
              autocomplete="tel"
              aria-label="Phone number (optional)"
            >
            <label class="newsletter-recapture-sms">
              <input type="checkbox" name="smsOptIn" value="yes">
              <span>
                <strong>Also send me text updates</strong> — by checking this box, you agree to receive recurring marketing texts from Pet Printables at the number above. Consent isn’t a condition of purchase. Msg &amp; data rates may apply. Reply STOP to opt out.
                <a href="/policies/terms-of-service" target="_blank" rel="noopener noreferrer">Terms</a> ·
                <a href="/policies/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy</a>.
              </span>
            </label>
            <p class="newsletter-recapture-error" role="alert" hidden></p>
            <button type="submit" class="btn btn--primary btn--full">
              You're right, gimme 10% off
            </button>
          </form>
          <button type="button" id="newsletter-recapture-skip" class="newsletter-recapture-skip">
            Yep, full price's fine
          </button>
        </div>
      </div>
    {%- else -%}
      <div class="cart-empty">
        <div class="cart-empty__icon">✦</div>
        <h2>Your cart is empty</h2>
        <p class="text-muted">Looks like you haven't added any portraits yet. Your pet deserves to be immortalised!</p>
        <a href="/pages/create" class="btn btn--primary btn--large" style="margin-top:24px;">
          Create Your First Portrait →
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  /* Priority Order upsell toggle ────────────────────────────────
     Fetches the priority-order product JSON once to get variant_id +
     price, renders the price, then wires the checkbox to POST to
     /cart/add.js (when checked) or /cart/change.js (when unchecked).
     No link to the product page exists — the JSON endpoint is used
     purely to resolve the variant. */
  (function () {
    var wrap = document.querySelector('[data-priority-upsell]');
    if (!wrap) return;
    var toggle = wrap.querySelector('#PriorityUpsellToggle');
    var priceEl = wrap.querySelector('[data-priority-price]');
    var statusEl = wrap.querySelector('[data-priority-status]');
    if (!toggle) return;

    var variantId = null;
    var pendingRequest = false;

    function formatMoney(cents) {
      try {
        return new Intl.NumberFormat('en-CA', {
          style: 'currency', currency: 'Cart.currency' === 'Cart.currency' ? 'CAD' : 'CAD',
          minimumFractionDigits: 2,
        }).format((cents || 0) / 100);
      } catch (e) {
        return '$' + (((cents || 0) / 100).toFixed(2));
      }
    }

    function setStatus(msg, isError) {
      if (!statusEl) return;
      statusEl.textContent = msg || '';
      statusEl.style.display = msg ? 'block' : 'none';
      statusEl.style.color = isError ? '#B00020' : 'var(--color-muted)';
    }

    function setBusy(busy) {
      pendingRequest = busy;
      toggle.disabled = busy;
      wrap.style.opacity = busy ? '0.65' : '1';
    }

    // Load variant id + price up front
    fetch('/products/priority-order.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { if (!r.ok) throw new Error('NOT_FOUND'); return r.json(); })
      .then(function (p) {
        var v = (p.variants && p.variants[0]) || null;
        if (!v) throw new Error('NO_VARIANT');
        variantId = v.id;
        if (priceEl) priceEl.textContent = '+' + formatMoney(v.price);
      })
      .catch(function () {
        // Product missing or draft — hide the upsell entirely so we
        // don't render a broken-looking toggle in production.
        wrap.style.display = 'none';
      });

    toggle.addEventListener('change', function () {
      if (pendingRequest) return;
      var wantOn = toggle.checked;

      if (wantOn) {
        if (!variantId) {
          toggle.checked = false;
          setStatus('Priority Order is temporarily unavailable.', true);
          return;
        }
        setBusy(true);
        setStatus('Adding priority to your order…');
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 }),
        })
          .then(function (r) { if (!r.ok) throw new Error('ADD_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = false;
            setStatus('Could not add Priority Order. Please try again.', true);
          });
      } else {
        // Remove by line key captured from the server-rendered attribute
        var lineKey = wrap.getAttribute('data-line-key') || '';
        if (!lineKey) { window.location.reload(); return; }
        setBusy(true);
        setStatus('Removing priority…');
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: lineKey, quantity: 0 }),
        })
          .then(function (r) { if (!r.ok) throw new Error('REMOVE_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = true;
            setStatus('Could not remove Priority Order. Please try again.', true);
          });
      }
    });
  })();

  /* Digital Files upsell toggle ─────────────────────────────────
     Same pattern as Priority Order: fetch the product's variant +
     price once, then POST to /cart/add.js or /cart/change.js when
     the user toggles. Hides itself if the product is missing/draft. */
  (function () {
    var wrap = document.querySelector('[data-digital-files-upsell]');
    if (!wrap) return;
    var toggle = wrap.querySelector('#DigitalFilesUpsellToggle');
    var priceEl = wrap.querySelector('[data-digital-files-price]');
    var statusEl = wrap.querySelector('[data-digital-files-status]');
    if (!toggle) return;

    var variantId = null;
    var pendingRequest = false;

    function formatMoney(cents) {
      try {
        return new Intl.NumberFormat('en-CA', {
          style: 'currency', currency: 'CAD',
          minimumFractionDigits: 2,
        }).format((cents || 0) / 100);
      } catch (e) {
        return '$' + (((cents || 0) / 100).toFixed(2));
      }
    }

    function setStatus(msg, isError) {
      if (!statusEl) return;
      statusEl.textContent = msg || '';
      statusEl.style.display = msg ? 'block' : 'none';
      statusEl.style.color = isError ? '#B00020' : 'var(--color-muted)';
    }

    function setBusy(busy) {
      pendingRequest = busy;
      toggle.disabled = busy;
      wrap.style.opacity = busy ? '0.65' : '1';
    }

    fetch('/products/digital-files.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { if (!r.ok) throw new Error('NOT_FOUND'); return r.json(); })
      .then(function (p) {
        var v = (p.variants && p.variants[0]) || null;
        if (!v) throw new Error('NO_VARIANT');
        variantId = v.id;
        if (priceEl) priceEl.textContent = '+' + formatMoney(v.price);
      })
      .catch(function () {
        wrap.style.display = 'none';
      });

    toggle.addEventListener('change', function () {
      if (pendingRequest) return;
      var wantOn = toggle.checked;

      if (wantOn) {
        if (!variantId) {
          toggle.checked = false;
          setStatus('Digital Files are temporarily unavailable.', true);
          return;
        }
        setBusy(true);
        setStatus('Adding digital files\u2026');
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 }),
        })
          .then(function (r) { if (!r.ok) throw new Error('ADD_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = false;
            setStatus('Could not add digital files. Please try again.', true);
          });
      } else {
        var lineKey = wrap.getAttribute('data-line-key') || '';
        if (!lineKey) { window.location.reload(); return; }
        setBusy(true);
        setStatus('Removing digital files\u2026');
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: lineKey, quantity: 0 }),
        })
          .then(function (r) { if (!r.ok) throw new Error('REMOVE_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = true;
            setStatus('Could not remove digital files. Please try again.', true);
          });
      }
    });
  })();

  /* Magnet upsell toggle + size picker ──────────────────────────
     Renders size chips populated from /products/magnet.js so the
     prices stay in sync with Shopify. Toggle checkbox adds/removes
     the selected variant. Changing size while in cart swaps the
     variant (remove old → add new). All magnet line items carry
     the source portrait's properties so fulfillment prints the
     same design. Hides itself if the product is missing/draft. */
  (function () {
    var wrap = document.querySelector('[data-magnet-upsell]');
    if (!wrap) return;
    var toggle = wrap.querySelector('#MagnetUpsellToggle');
    var priceEl = wrap.querySelector('[data-magnet-price]');
    var statusEl = wrap.querySelector('[data-magnet-status]');
    var sizesEl = wrap.querySelector('[data-magnet-sizes]');
    if (!toggle || !sizesEl) return;

    var variants = [];
    var selectedVariantId = null;
    var pendingRequest = false;

    function formatMoney(cents) {
      try {
        return new Intl.NumberFormat('en-CA', {
          style: 'currency', currency: 'CAD',
          minimumFractionDigits: 2,
        }).format((cents || 0) / 100);
      } catch (e) {
        return '$' + (((cents || 0) / 100).toFixed(2));
      }
    }

    function setStatus(msg, isError) {
      if (!statusEl) return;
      statusEl.textContent = msg || '';
      statusEl.style.display = msg ? 'block' : 'none';
      statusEl.style.color = isError ? '#B00020' : 'var(--color-muted)';
    }

    function setBusy(busy) {
      pendingRequest = busy;
      toggle.disabled = busy;
      sizesEl.querySelectorAll('button').forEach(function (b) { b.disabled = busy; });
      wrap.style.opacity = busy ? '0.65' : '1';
    }

    function buildProperties() {
      var d = wrap.dataset;
      var props = {};
      if (d.petName) props['Pet Name'] = d.petName;
      if (d.style) props['_Style'] = d.style;
      if (d.jobId) props['_Job ID'] = d.jobId;
      if (d.showName) props['_Show Name'] = d.showName;
      if (d.portraitUrl) props['_Portrait URL'] = d.portraitUrl;
      if (d.printUrl) props['_Print File URL'] = d.printUrl;
      if (d.noNameUrl) props['_No Name URL'] = d.noNameUrl;
      // Tag the line item so fulfillment routes it to the magnet pipeline.
      // Shopify line items don't carry a product handle, so without this the
      // backend defaults to canvas and the order can't be fulfilled.
      props['_Product type'] = 'magnet';
      return props;
    }

    // Normalize labels like 3″×3″ / 4"x4" to a compact "3\u00d73".
    function shortSizeLabel(title) {
      if (!title) return '';
      var t = String(title).replace(/["'\u2032\u2033\u00b4]/g, '').replace(/\s+/g, '');
      var m = t.match(/(\d+)[x\u00d7](\d+)/i);
      return m ? m[1] + '\u00d7' + m[2] : title;
    }

    function renderHeaderPrice() {
      if (!priceEl) return;
      var v = variants.find(function (x) { return x.id === selectedVariantId; });
      priceEl.textContent = v ? '+' + formatMoney(v.price) : '';
    }

    function renderSizes() {
      sizesEl.innerHTML = '';
      variants.forEach(function (v) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('role', 'radio');
        btn.setAttribute('data-variant-id', v.id);
        var selected = v.id === selectedVariantId;
        btn.setAttribute('aria-checked', selected ? 'true' : 'false');
        btn.style.cssText =
          'padding:6px 12px;border-radius:999px;cursor:pointer;' +
          'font-family:var(--font-body);font-size:var(--text-sm);font-weight:500;' +
          'transition:all 0.15s ease;min-height:32px;' +
          (selected
            ? 'background:var(--color-ink);color:#fff;border:1px solid var(--color-ink);'
            : 'background:transparent;color:var(--color-ink);border:1px solid var(--color-border);');
        btn.innerHTML =
          '<span style="font-weight:600;">' + shortSizeLabel(v.title) + '</span>' +
          '<span style="margin-left:6px;opacity:0.75;font-size:var(--text-xs);">' + formatMoney(v.price) + '</span>';
        btn.addEventListener('click', function () { onSizeClick(v.id); });
        sizesEl.appendChild(btn);
      });
      sizesEl.style.display = variants.length > 1 ? 'flex' : 'none';
      renderHeaderPrice();
    }

    function onSizeClick(newVariantId) {
      if (pendingRequest) return;
      if (newVariantId === selectedVariantId) return;
      var wasInCart = toggle.checked;
      var oldLineKey = wrap.getAttribute('data-line-key') || '';
      selectedVariantId = newVariantId;
      renderSizes();

      if (!wasInCart) return; // just updated the selection, nothing to sync server-side

      // Swap the variant: remove old, add new with same properties.
      setBusy(true);
      setStatus('Updating magnet size\u2026');
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: oldLineKey, quantity: 0 }),
      })
        .then(function (r) { if (!r.ok) throw new Error('REMOVE_FAILED'); return r.json(); })
        .then(function () {
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ id: selectedVariantId, quantity: 1, properties: buildProperties() }),
          });
        })
        .then(function (r) { if (!r.ok) throw new Error('ADD_FAILED'); return r.json(); })
        .then(function () { window.location.reload(); })
        .catch(function () {
          setBusy(false);
          setStatus('Could not switch magnet size. Please try again.', true);
        });
    }

    fetch('/products/magnet.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { if (!r.ok) throw new Error('NOT_FOUND'); return r.json(); })
      .then(function (p) {
        variants = (p.variants || []).filter(function (v) { return v.available; });
        if (!variants.length) throw new Error('NO_VARIANT');
        // Preselect: the variant that's already in cart (if any), else 4"x4",
        // else the first available variant.
        var currentInCart = parseInt(wrap.getAttribute('data-current-variant-id') || '0', 10) || null;
        var preferred = (currentInCart && variants.find(function (v) { return v.id === currentInCart; }))
          || variants.find(function (v) { return /4.{1,2}[x\u00d7].{0,2}4/i.test(v.title || ''); })
          || variants[0];
        selectedVariantId = preferred.id;
        renderSizes();
      })
      .catch(function () {
        wrap.style.display = 'none';
      });

    toggle.addEventListener('change', function () {
      if (pendingRequest) return;
      var wantOn = toggle.checked;

      if (wantOn) {
        if (!selectedVariantId) {
          toggle.checked = false;
          setStatus('Magnets are temporarily unavailable.', true);
          return;
        }
        setBusy(true);
        setStatus('Adding magnet to your order\u2026');
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: selectedVariantId, quantity: 1, properties: buildProperties() }),
        })
          .then(function (r) { if (!r.ok) throw new Error('ADD_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = false;
            setStatus('Could not add the magnet. Please try again.', true);
          });
      } else {
        var lineKey = wrap.getAttribute('data-line-key') || '';
        if (!lineKey) { window.location.reload(); return; }
        setBusy(true);
        setStatus('Removing magnet\u2026');
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: lineKey, quantity: 0 }),
        })
          .then(function (r) { if (!r.ok) throw new Error('REMOVE_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = true;
            setStatus('Could not remove the magnet. Please try again.', true);
          });
      }
    });
  })();

  /* Shipping estimator ─────────────────────────────────────────
     Calls Shopify's /cart/shipping_rates.json with the entered
     postal code. Same carrier rates as checkout, so the estimate
     is accurate — differences at checkout come from discounts,
     final addresses, or carrier updates. */
  (function () {
    var wrap = document.querySelector('[data-shipping-estimator]');
    if (!wrap) return;
    var input = wrap.querySelector('#ShippingEstPostal');
    var btn = wrap.querySelector('[data-shipping-estimate-btn]');
    var resultEl = wrap.querySelector('[data-shipping-result]');
    if (!input || !btn || !resultEl) return;

    var SHOP_CURRENCY = {{ cart.currency.iso_code | json }};

    function formatMoneyFromDollars(dollarStr) {
      var n = parseFloat(dollarStr);
      if (!isFinite(n)) return dollarStr;
      try {
        return new Intl.NumberFormat('en-CA', {
          style: 'currency', currency: SHOP_CURRENCY || 'CAD',
          minimumFractionDigits: 2,
        }).format(n);
      } catch (e) {
        return '$' + n.toFixed(2);
      }
    }

    function escapeHtml(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function showResult(html, isError) {
      resultEl.innerHTML = html;
      resultEl.style.display = 'block';
      resultEl.style.color = isError ? '#B00020' : 'var(--color-ink)';
    }

    // Guess the country from the postal pattern. CA uses "A1A 1A1",
    // US uses 5 digits (optionally 5-4). Default to Canada.
    function guessCountry(zip) {
      var bare = zip.replace(/\s+/g, '').toUpperCase();
      if (/^[A-Z]\d[A-Z]\d[A-Z]\d$/.test(bare)) return 'Canada';
      if (/^\d{5}(-\d{4})?$/.test(bare)) return 'United States';
      return 'Canada';
    }

    // Shopify's rates endpoint is strict about postal format.
    // Canadian codes must be "A1A 1A1" (space required). US codes must
    // be 5 digits or 5-4. Normalize before sending to avoid false 422s.
    function normalizeZip(zip, country) {
      var bare = zip.replace(/\s+/g, '').toUpperCase();
      if (country === 'Canada' && /^[A-Z]\d[A-Z]\d[A-Z]\d$/.test(bare)) {
        return bare.slice(0, 3) + ' ' + bare.slice(3);
      }
      if (country === 'United States' && /^\d{9}$/.test(bare)) {
        return bare.slice(0, 5) + '-' + bare.slice(5);
      }
      return bare;
    }

    // Shopify's rates endpoint also requires a province/state for
    // Canadian and US addresses. Derive it from the postal code so the
    // user doesn't need to pick one.
    //   Canadian FSA first letter → province (Canada Post mapping).
    //   US ZIP range → state (first 3 digits).
    var CA_PROVINCE_BY_FSA = {
      A: 'NL', B: 'NS', C: 'PE', E: 'NB', G: 'QC', H: 'QC', J: 'QC',
      K: 'ON', L: 'ON', M: 'ON', N: 'ON', P: 'ON',
      R: 'MB', S: 'SK', T: 'AB', V: 'BC', X: 'NT', Y: 'YT',
    };
    function guessProvinceOrState(zip, country) {
      var bare = zip.replace(/\s+/g, '').toUpperCase();
      if (country === 'Canada') {
        return CA_PROVINCE_BY_FSA[bare.charAt(0)] || '';
      }
      return ''; // US state lookup by ZIP is large; leave blank for now.
    }

    function fetchRates(zip, country) {
      var params = new URLSearchParams();
      params.append('shipping_address[zip]', zip);
      params.append('shipping_address[country]', country);
      var province = guessProvinceOrState(zip, country);
      if (province) params.append('shipping_address[province]', province);
      return fetch('/cart/shipping_rates.json?' + params.toString(), {
        headers: { 'Accept': 'application/json' },
      }).then(function (r) {
        if (r.status === 422) {
          // Shopify returns a structured error body. Parse it so we can
          // distinguish a bad postal code from other failures (e.g. no
          // shippable items in the cart, or address not reachable).
          return r.json().then(function (body) {
            var detail = '';
            try {
              if (body && typeof body === 'object') {
                // Typical shape: { "shipping_address": ["message1", ...] }
                for (var k in body) {
                  if (!body.hasOwnProperty(k)) continue;
                  var v = body[k];
                  if (Array.isArray(v)) detail = v.join(' ');
                  else if (typeof v === 'string') detail = v;
                  if (detail) break;
                }
              }
            } catch (e) { /* ignore — generic fallback */ }
            var err = new Error(detail || 'INVALID_ADDRESS');
            err.code = 'SHOPIFY_422';
            err.detail = detail;
            throw err;
          }).catch(function (e) {
            if (e && e.code === 'SHOPIFY_422') throw e;
            var fallback = new Error('INVALID_ADDRESS');
            fallback.code = 'SHOPIFY_422';
            throw fallback;
          });
        }
        if (!r.ok) throw new Error('REQUEST_FAILED');
        return r.json();
      });
    }

    function runEstimate() {
      var zip = (input.value || '').trim().toUpperCase();
      if (!zip) {
        showResult('Please enter a postal code.', true);
        input.focus();
        return;
      }
      var country = guessCountry(zip);
      zip = normalizeZip(zip, country);
      btn.disabled = true;
      showResult('Getting an estimate\u2026', false);
      fetchRates(zip, country)
        .then(function (data) {
          btn.disabled = false;
          var rates = (data && data.shipping_rates) || [];
          if (!rates.length) {
            showResult(
              'No shipping options found for <strong>' + escapeHtml(zip) + '</strong>. '
              + 'Double-check the postal code, or see final shipping at checkout.',
              true
            );
            return;
          }
          // Show all rates sorted cheapest → most expensive.
          var sorted = rates.slice().sort(function (a, b) {
            return parseFloat(a.price) - parseFloat(b.price);
          });
          var rows = sorted.map(function (r) {
            var label = escapeHtml(r.presentment_name || r.name || 'Shipping');
            var price = formatMoneyFromDollars(r.price);
            return '<li style="display:flex;justify-content:space-between;gap:12px;padding:3px 0;">'
              + '<span>' + label + '</span>'
              + '<strong>' + escapeHtml(price) + '</strong>'
              + '</li>';
          }).join('');
          showResult(
            '<div style="font-weight:600;margin-bottom:4px;">Estimated shipping to ' + escapeHtml(zip) + ':</div>'
            + '<ul style="list-style:none;margin:0;padding:0;">' + rows + '</ul>',
            false
          );
        })
        .catch(function (err) {
          btn.disabled = false;
          var detail = (err && err.detail) || (err && err.message) || '';
          if (err && err.code === 'SHOPIFY_422') {
            // Route Shopify's specific 422 reasons to clear user messages.
            if (/province|state/i.test(detail)) {
              showResult(
                "We couldn\u2019t figure out the province from that postal code. "
                + "Please double-check the postal code and try again.",
                true
              );
            } else if (/zip|postal/i.test(detail)) {
              showResult(
                "That postal code didn\u2019t look right for <strong>" + escapeHtml(country) + "</strong>. "
                + "Canadian codes look like <code>V6Z 2A9</code>; US codes are 5 digits.",
                true
              );
            } else if (/no\s+shipping|no\s+rates|not\s+shippable|cannot\s+be\s+shipped|no\s+shippable/i.test(detail)) {
              showResult(
                "No shipping needed \u2014 the items in your cart are digital-only. "
                + "You\u2019ll get them by email after checkout.",
                false
              );
            } else if (/country/i.test(detail)) {
              showResult(
                "We can\u2019t ship to that country yet. We currently ship within Canada only.",
                true
              );
            } else if (detail) {
              showResult("Couldn\u2019t estimate shipping: " + escapeHtml(detail), true);
            } else {
              showResult("That address didn\u2019t work. Please check the postal code and try again.", true);
            }
          } else {
            showResult("Couldn\u2019t fetch an estimate right now. You can see shipping at checkout.", true);
          }
        });
    }

    btn.addEventListener('click', runEstimate);
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); runEstimate(); }
    });
  })();

  /* Free-shipping celebration — trigger on cart page load when the
     current cart is over the $95 threshold and this session hasn't
     celebrated yet. theme.js defines window.petPrintables.maybeCelebrateFreeShipping
     and handles session-scoped de-dupe. */
  (function () {
    function fire() {
      var fn = window.petPrintables && window.petPrintables.maybeCelebrateFreeShipping;
      if (typeof fn === 'function') fn({{ cart.total_price }});
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fire);
    } else {
      fire();
    }
  })();

  /* Replace cart thumbnails with the actual generated portrait from localStorage */
  (function () {
    try {
      var raw = localStorage.getItem('petPrintables_session');
      if (!raw) return;
      var data = JSON.parse(raw);
      if (!data) return;

      // Prefer CDN URLs, then data URLs (base64)
      var cdnUrls = data.previewCdnUrls || [];
      var dataUrls = data.previewDataUrls || [];
      var idx = data.selectedPreviewIndex || 0;
      var portraitSrc = cdnUrls[idx] || cdnUrls[0] || dataUrls[idx] || dataUrls[0];
      if (!portraitSrc) return;

      document.querySelectorAll('.cart-page__item-img img').forEach(function (img) {
        img.src = portraitSrc;
        img.srcset = '';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '8px';

        // If CDN URL fails to load, fall back to base64 data URL
        img.onerror = function () {
          var fallback = dataUrls[idx] || dataUrls[0];
          if (fallback && img.src !== fallback) {
            img.src = fallback;
          }
        };
      });
    } catch (e) {}
  })();

  /* ── Name-on-portrait toggle (cart page) ────────────────────
   * Lets user flip between with-name and no-name versions.
   * Updates line item properties via Shopify Ajax API + live
   * swaps the preview image. Calls /add-name to generate the
   * with-name version if we don't already have it.
   */
  (function () {
    var API_BASE = (window.petPrintables && window.petPrintables.previewApi) || 'https://web-production-a392e.up.railway.app';

    document.querySelectorAll('.cart-page__item').forEach(function (itemEl) {
      var petName = itemEl.dataset.petName;
      var style = itemEl.dataset.style;
      if (!petName) return;

      var buttons = itemEl.querySelectorAll('.cart-name-btn');
      var statusEl = itemEl.querySelector('.cart-name-status');
      var imgEl = itemEl.querySelector('.cart-page__portrait-preview');
      var key = itemEl.getAttribute('data-cart-item');

      function updateButtonStyles(activeValue) {
        buttons.forEach(function (btn) {
          var isActive = btn.dataset.nameValue === activeValue;
          btn.style.background = isActive ? 'var(--color-ink)' : 'transparent';
          btn.style.color = isActive ? '#fff' : 'var(--color-ink)';
          btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      }

      function updateCart(properties) {
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: key, properties: properties }),
        }).then(function (r) { return r.json(); });
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var value = btn.dataset.nameValue;
          var current = itemEl.dataset.showName;
          if (value === current) return;

          // Gather all existing properties so we don't lose them on the update
          var existingProps = {};
          // Shopify's /cart/change.js needs the FULL properties object;
          // read from hidden item data we already stored.
          existingProps['Pet Name'] = petName;
          if (style) existingProps['_Style'] = style;
          if (itemEl.dataset.jobId) existingProps['_Job ID'] = itemEl.dataset.jobId;

          if (value === 'No') {
            // Switch to no-name version
            var noNameUrl = itemEl.dataset.noNameUrl;
            if (!noNameUrl) {
              // Fall back: same as portrait URL (won't actually remove name
              // unless the no-name URL was stored at ATC time)
              noNameUrl = itemEl.dataset.portraitUrl;
            }
            existingProps['_Show Name'] = 'No';
            existingProps['_Portrait URL'] = noNameUrl;
            existingProps['_Print File URL'] = noNameUrl;
            btn.disabled = true;
            updateCart(existingProps).then(function () {
              if (imgEl) imgEl.src = noNameUrl;
              itemEl.dataset.showName = 'No';
              itemEl.dataset.portraitUrl = noNameUrl;
              updateButtonStyles('No');
              btn.disabled = false;
              if (statusEl) { statusEl.textContent = 'Updated'; statusEl.style.display = 'inline'; setTimeout(function(){statusEl.style.display='none';}, 2000); }
            });
          } else {
            // Switch to with-name version — generate on the fly
            var sourceUrl = itemEl.dataset.noNameUrl || itemEl.dataset.portraitUrl;
            if (!sourceUrl) return;

            // Inject spinner keyframe once per page
            if (!document.getElementById('cart-addname-spin-kf')) {
              var kf = document.createElement('style');
              kf.id = 'cart-addname-spin-kf';
              kf.textContent = '@keyframes cartAddNameSpin{to{transform:rotate(360deg)}}';
              document.head.appendChild(kf);
            }

            // Disable BOTH toggle buttons and show spinner + progressive copy
            buttons.forEach(function(b){ b.disabled = true; b.style.opacity = '0.6'; b.style.cursor = 'wait'; });
            if (statusEl) {
              statusEl.innerHTML = '<span style="display:inline-flex;align-items:center;gap:8px;">'
                + '<span aria-hidden="true" style="width:12px;height:12px;border:2px solid var(--color-border,#e5e0db);'
                + 'border-top-color:var(--color-primary,#c4903e);border-radius:50%;animation:cartAddNameSpin 0.9s linear infinite;display:inline-block;"></span>'
                + '<span data-addname-cart-label>Adding the name\u2026</span>'
                + '</span>';
              statusEl.style.display = 'inline-flex';
              statusEl.setAttribute('role', 'status');
              statusEl.setAttribute('aria-live', 'polite');
            }

            var PHRASES = ['Adding the name\u2026', 'Painting the letters\u2026', 'Blending it in\u2026', 'Almost done\u2026'];
            var phaseIdx = 0;
            var cycler = setInterval(function () {
              phaseIdx = Math.min(phaseIdx + 1, PHRASES.length - 1);
              var lbl = statusEl && statusEl.querySelector('[data-addname-cart-label]');
              if (lbl) lbl.textContent = PHRASES[phaseIdx];
            }, 3500);

            function finishLoadingUI() {
              clearInterval(cycler);
              buttons.forEach(function(b){ b.disabled = false; b.style.opacity = ''; b.style.cursor = ''; });
            }

            fetch(API_BASE + '/add-name', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                image_url: sourceUrl,
                pet_name: petName,
                style: style,
              }),
            })
            .then(function (r) { return r.ok ? r.json() : r.json().then(function (d) { throw new Error(d.error || 'Failed'); }); })
            .then(function (resp) {
              var newUrl = resp.composited || resp.composited_png_cdn;
              existingProps['_Show Name'] = 'Yes';
              existingProps['_Portrait URL'] = newUrl;
              existingProps['_Print File URL'] = resp.composited_png_cdn || newUrl;
              existingProps['_No Name URL'] = sourceUrl;  // preserve for future toggling
              return updateCart(existingProps).then(function () {
                if (imgEl) imgEl.src = newUrl;
                itemEl.dataset.showName = 'Yes';
                itemEl.dataset.portraitUrl = newUrl;
                itemEl.dataset.noNameUrl = sourceUrl;
                updateButtonStyles('Yes');
                finishLoadingUI();
                if (statusEl) {
                  statusEl.textContent = 'Updated';
                  statusEl.style.display = 'inline';
                  setTimeout(function(){statusEl.style.display='none';}, 2000);
                }
              });
            })
            .catch(function (err) {
              finishLoadingUI();
              if (statusEl) {
                statusEl.textContent = 'Error — ' + (err.message || err);
                statusEl.style.display = 'inline';
                setTimeout(function(){statusEl.style.display='none';}, 3000);
              }
            });
          }
        });
      });
    });
  })();

  /* ──────────────────────────────────────────────────────────────
   * Priority-order upsell.
   * On check: adds the "priority-order" Shopify product (variant ID
   *   in data-variant-id) as a $5.01 line item AND sets the cart
   *   attribute `Priority order: Yes` for the ops team.
   * On uncheck: removes the line item AND sets the attribute to "No".
   * Reloads the page after either operation so the cart subtotal,
   * free-ship tracker, and checkout button stay in sync — same
   * pattern as the magnet upsell.
   * ────────────────────────────────────────────────────────────── */
  (function () {
    var toggle = document.querySelector('[data-priority-toggle]');
    if (!toggle) return;
    var checkbox = toggle.querySelector('[data-priority-checkbox]');
    var status = toggle.querySelector('[data-priority-status]');
    var tipBtn = toggle.querySelector('.priority-tooltip');
    var variantId = parseInt(toggle.getAttribute('data-variant-id'), 10);

    /* Mobile: tap-to-toggle the tooltip (CSS hover doesn't fire on touch). */
    if (tipBtn) {
      tipBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        e.preventDefault();
        tipBtn.classList.toggle('is-open');
      });
      tipBtn.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          tipBtn.classList.toggle('is-open');
        }
        if (e.key === 'Escape') tipBtn.classList.remove('is-open');
      });
      document.addEventListener('click', function (e) {
        if (!tipBtn.contains(e.target)) tipBtn.classList.remove('is-open');
      });
    }

    if (!checkbox || !variantId) return;

    function setStatus(text, isError) {
      if (!status) return;
      status.textContent = text || '';
      status.style.color = isError ? 'var(--color-warning, #B45309)' : 'var(--color-muted)';
    }

    function setAttribute(value) {
      return fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ attributes: { 'Priority order': value } }),
      });
    }

    function addPriority() {
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 }),
      })
        .then(function (r) { if (!r.ok) throw new Error('ADD_FAILED'); return r.json(); })
        .then(function () { return setAttribute('Yes'); });
    }

    function removePriority() {
      var lineKey = toggle.getAttribute('data-line-key');
      /* If we don't have a stored line key (e.g. user double-clicked or
       * the page didn't re-render), fall back to changing by variant id
       * — Shopify's /cart/change.js accepts an `id` of either a line
       * key or a variant id. */
      var body = lineKey
        ? { id: lineKey, quantity: 0 }
        : { id: variantId, quantity: 0 };
      return fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(body),
      })
        .then(function (r) { if (!r.ok) throw new Error('REMOVE_FAILED'); return r.json(); })
        .then(function () { return setAttribute('No'); });
    }

    checkbox.addEventListener('change', function () {
      var nowOn = checkbox.checked;
      checkbox.disabled = true;
      setStatus(nowOn ? 'Adding priority…' : 'Removing priority…');
      var op = nowOn ? addPriority() : removePriority();
      op
        .then(function () { window.location.reload(); })
        .catch(function () {
          /* Revert the checkbox so the UI matches server state. */
          checkbox.checked = !checkbox.checked;
          setStatus('Could not update — please try again', true);
          checkbox.disabled = false;
        });
    });
  })();

  /* ──────────────────────────────────────────────────────────────
   * Newsletter recapture — final-chance modal for shoppers who
   * skipped the 10%-off popup on the create page. Triggered only
   * if pf_newsletter_status === 'skipped'. Submits email to
   * Shopify newsletter (/contact) + applies /discount/PETFAM2026,
   * then continues to checkout. Skipping the recapture proceeds
   * straight to checkout untouched.
   * ────────────────────────────────────────────────────────────── */
  (function () {
    var status;
    try { status = localStorage.getItem('pf_newsletter_status'); }
    catch (e) { status = null; }
    if (status !== 'skipped') return;

    var checkoutBtn = document.querySelector('[data-checkout-btn]');
    var modal = document.getElementById('newsletter-recapture-backdrop');
    var form = document.getElementById('newsletter-recapture-form');
    var skipBtn = document.getElementById('newsletter-recapture-skip');
    var errorEl = modal && modal.querySelector('.newsletter-recapture-error');
    if (!checkoutBtn || !modal || !form || !skipBtn) return;

    var pendingHref = null;
    var submitting = false;

    function showError(msg) {
      if (!errorEl) return;
      errorEl.textContent = msg || '';
      errorEl.hidden = !msg;
    }

    function openModal(href) {
      pendingHref = href;
      modal.hidden = false;
      var emailInput = form.querySelector('input[name="email"]');
      if (emailInput) setTimeout(function () { emailInput.focus(); }, 50);
    }
    function closeModal() {
      modal.hidden = true;
      showError('');
    }

    checkoutBtn.addEventListener('click', function (e) {
      // Re-check status just-in-time in case it changed in another tab.
      var currentStatus;
      try { currentStatus = localStorage.getItem('pf_newsletter_status'); }
      catch (err) { currentStatus = null; }
      if (currentStatus !== 'skipped') return;
      e.preventDefault();
      openModal(checkoutBtn.href || '/checkout');
    });

    function normalizePhoneE164(raw) {
      if (!raw) return null;
      var trimmed = String(raw).trim();
      var compact = trimmed.replace(/\s|-|\(|\)/g, '');
      if (/^\+\d{10,15}$/.test(compact)) return compact;
      var digits = trimmed.replace(/\D/g, '');
      if (digits.length === 10) return '+1' + digits;
      if (digits.length === 11 && digits.charAt(0) === '1') return '+' + digits;
      return null;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (submitting) return;
      var firstName = (form.firstName.value || '').trim();
      var lastName  = (form.lastName.value  || '').trim();
      var email     = (form.email.value     || '').trim();
      var phoneRaw  = (form.phone.value     || '').trim();
      var smsOptIn  = !!form.smsOptIn.checked;

      if (!firstName || !lastName) {
        showError('Need your first and last name.');
        return;
      }
      if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
        showError('That email looks off — double-check it?');
        return;
      }
      var phoneE164 = null;
      if (smsOptIn) {
        phoneE164 = normalizePhoneE164(phoneRaw);
        if (!phoneE164) {
          showError('Need a valid phone number to opt into SMS (or uncheck the box).');
          return;
        }
      }

      submitting = true;
      showError('');
      var submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Signing you up…';
      }

      // Build Klaviyo Client Subscriptions API payload
      var klaviyo = (window.petPrintables && window.petPrintables.klaviyo) || {};
      var companyId = klaviyo.publicKey;
      var listId    = klaviyo.listId;

      var subscriptions = { email: { marketing: { consent: 'SUBSCRIBED' } } };
      if (phoneE164 && smsOptIn) {
        subscriptions.sms = { marketing: { consent: 'SUBSCRIBED' } };
      }
      var profileAttrs = {
        email: email,
        first_name: firstName,
        last_name: lastName,
        subscriptions: subscriptions,
        properties: { source: 'cart-recapture' }
      };
      if (phoneE164 && smsOptIn) profileAttrs.phone_number = phoneE164;

      var payload = {
        data: {
          type: 'subscription',
          attributes: {
            custom_source: 'Pet Printables — Cart Recapture',
            profile: { data: { type: 'profile', attributes: profileAttrs } }
          },
          relationships: { list: { data: { type: 'list', id: listId } } }
        }
      };

      // Klaviyo subscribe + apply discount cookie. Discount is the priority
      // here — if Klaviyo errors out, we still want to ship the customer
      // to checkout with the 10% applied (better UX than a hard error).
      var klaviyoCall = (companyId && listId)
        ? fetch(
            'https://a.klaviyo.com/client/subscriptions?company_id=' + encodeURIComponent(companyId),
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'revision': '2024-10-15' },
              body: JSON.stringify(payload)
            }
          ).catch(function () {})
        : Promise.resolve();
      var discountCall = fetch('/discount/PETFAM2026', {
        credentials: 'same-origin', redirect: 'manual'
      }).catch(function () {});

      Promise.allSettled([klaviyoCall, discountCall]).then(function () {
        try { localStorage.setItem('pf_newsletter_status', 'signed_up'); }
        catch (err) {}
        window.location.href = pendingHref || '/checkout';
      });
    });

    skipBtn.addEventListener('click', function () {
      // They confirmed they don't want the discount — proceed to checkout
      // and don't bug them again on this cart by leaving status as 'skipped'.
      closeModal();
      window.location.href = pendingHref || '/checkout';
    });

    // Close on backdrop click (treat as skip).
    modal.addEventListener('click', function (e) {
      if (e.target === modal) {
        closeModal();
        window.location.href = pendingHref || '/checkout';
      }
    });

    // ESC key to dismiss (treat as skip).
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) {
        closeModal();
        window.location.href = pendingHref || '/checkout';
      }
    });
  })();
</script>

