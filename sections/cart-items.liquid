<div class="cart-page">
  <div class="container container--mid">
    {%- render 'breadcrumbs' -%}
    <h1 class="cart-page__title">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      <div class="cart-page__layout">
        <div class="cart-page__items">
          {%- for item in cart.items -%}
            {%- assign portrait_url = nil -%}
            {%- assign no_name_url = nil -%}
            {%- assign show_name = 'Yes' -%}
            {%- assign pet_name_val = '' -%}
            {%- assign style_val = '' -%}
            {%- assign job_id_val = '' -%}
            {%- for property in item.properties -%}
              {%- if property.first == '_Portrait URL' and property.last != blank -%}{%- assign portrait_url = property.last -%}{%- endif -%}
              {%- if property.first == '_No Name URL' and property.last != blank -%}{%- assign no_name_url = property.last -%}{%- endif -%}
              {%- if property.first == '_Show Name' -%}{%- assign show_name = property.last -%}{%- endif -%}
              {%- if property.first == 'Pet Name' -%}{%- assign pet_name_val = property.last -%}{%- endif -%}
              {%- if property.first == '_Style' -%}{%- assign style_val = property.last -%}{%- endif -%}
              {%- if property.first == '_Job ID' -%}{%- assign job_id_val = property.last -%}{%- endif -%}
            {%- endfor -%}
            <div class="cart-page__item"
                 data-cart-item="{{ item.key }}"
                 data-show-name="{{ show_name }}"
                 data-pet-name="{{ pet_name_val | escape }}"
                 data-style="{{ style_val | escape }}"
                 data-job-id="{{ job_id_val | escape }}"
                 data-portrait-url="{{ portrait_url | default: '' | escape }}"
                 data-no-name-url="{{ no_name_url | default: '' | escape }}">
              <div class="cart-page__item-img">
                {%- if portrait_url -%}
                  <img src="{{ portrait_url }}" alt="{{ item.title }}" loading="lazy" class="cart-page__portrait-preview" style="width:100%;border-radius:8px;object-fit:cover;">
                {%- elsif item.image -%}
                  {{- item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title -}}
                {%- endif -%}
              </div>
              <div class="cart-page__item-info">
                <div class="cart-page__item-header">
                  <div>
                    <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p class="cart-page__item-variant text-muted">{{ item.variant.title }}</p>
                    {%- endunless -%}
                    {%- for property in item.properties -%}
                      {%- unless property.last == blank -%}
                        {%- assign prop_first_char = property.first | slice: 0 -%}
                        {%- unless prop_first_char == '_' -%}
                          <p class="cart-page__item-prop text-muted" style="font-size:0.85rem;">
                            {{ property.first }}: {{ property.last }}
                          </p>
                        {%- endunless -%}
                      {%- endunless -%}
                    {%- endfor -%}
                  </div>
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0"
                     class="cart-page__remove" aria-label="Remove {{ item.title | escape }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </a>
                </div>
                {%- if pet_name_val != blank -%}
                <div class="cart-page__name-toggle" style="display:flex;align-items:center;gap:8px;margin:10px 0;font-size:0.85rem;">
                  <span style="color:var(--color-muted);">Name on portrait:</span>
                  <button type="button" class="cart-name-btn" data-name-value="Yes"
                          aria-pressed="{% if show_name == 'Yes' %}true{% else %}false{% endif %}"
                          style="padding:4px 12px;border-radius:14px;border:1px solid var(--color-border);cursor:pointer;font-size:0.82rem;font-weight:500;background:{% if show_name == 'Yes' %}var(--color-ink);color:#fff;{% else %}transparent;color:var(--color-ink);{% endif %}">Yes</button>
                  <button type="button" class="cart-name-btn" data-name-value="No"
                          aria-pressed="{% if show_name == 'No' %}true{% else %}false{% endif %}"
                          style="padding:4px 12px;border-radius:14px;border:1px solid var(--color-border);cursor:pointer;font-size:0.82rem;font-weight:500;background:{% if show_name == 'No' %}var(--color-ink);color:#fff;{% else %}transparent;color:var(--color-ink);{% endif %}">No</button>
                  <span class="cart-name-status" style="color:var(--color-muted);font-size:0.78rem;display:none;"></span>
                </div>
                {%- endif -%}
                <div class="cart-page__item-footer">
                  <div class="cart-qty">
                    <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="cart-qty__btn" aria-label="Decrease quantity">−</a>
                    <span class="cart-qty__num">{{ item.quantity }}</span>
                    <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="cart-qty__btn" aria-label="Increase quantity">+</a>
                  </div>
                  <span class="cart-page__item-price">{{ item.final_line_price | money }} CAD</span>
                </div>
              </div>
            </div>
          {%- endfor -%}

          <!-- Add another portrait CTA -->
          <a href="/pages/create" class="cart-add-another" style="display:flex;align-items:center;justify-content:center;gap:10px;padding:18px;margin-top:12px;border:1.5px dashed var(--color-border);border-radius:var(--radius-card);background:var(--color-surface);text-decoration:none;color:var(--color-ink);font-family:var(--font-body);font-size:0.95rem;font-weight:500;transition:all 0.2s;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m-8-8h16"/>
            </svg>
            <span>Create another portrait for your family</span>
          </a>
        </div>

        <aside class="cart-page__summary">
          <div class="cart-summary">
            <h2 class="cart-summary__title">Order Summary</h2>
            <div class="cart-summary__row">
              <span>Subtotal ({{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %})</span>
              <span>{{ cart.total_price | money }} CAD</span>
            </div>
            {%- if cart.total_discounts > 0 -%}
              <div class="cart-summary__row cart-summary__row--discount">
                <span>Discounts</span>
                <span>−{{ cart.total_discounts | money }}</span>
              </div>
            {%- endif -%}

            {%- comment -%}
              Free shipping threshold tracker
              cart.total_price is in cents — $85 CAD = 8500 cents
            {%- endcomment -%}
            {%- assign free_ship_cents = 8500 -%}
            {%- assign remaining_cents = free_ship_cents | minus: cart.total_price -%}
            {%- if remaining_cents > 0 -%}
              {%- assign progress_pct = cart.total_price | times: 100.0 | divided_by: free_ship_cents -%}
              <div class="free-ship-tracker" style="margin:14px 0;padding:14px;background:var(--color-surface);border-radius:var(--radius-card);border:1px solid var(--color-border);">
                <div style="display:flex;align-items:center;gap:8px;font-size:0.85rem;color:var(--color-ink);margin-bottom:10px;line-height:1.4;">
                  <span aria-hidden="true" style="font-size:1.1em;">🚚</span>
                  <span>You're <strong style="font-weight:700;color:var(--color-primary);">{{ remaining_cents | money }}</strong> away from free shipping</span>
                </div>
                <div style="height:6px;background:var(--color-border);border-radius:99px;overflow:hidden;">
                  <div style="height:100%;width:{{ progress_pct }}%;background:linear-gradient(90deg,var(--color-primary),var(--color-accent));border-radius:99px;transition:width 0.5s ease;"></div>
                </div>
                <a href="/pages/create" style="display:inline-flex;align-items:center;gap:6px;margin-top:10px;font-size:0.82rem;font-weight:600;color:var(--color-primary);text-decoration:none;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m-8-8h16"/>
                  </svg>
                  Add another portrait to qualify
                </a>
              </div>
            {%- else -%}
              <div class="free-ship-tracker free-ship-tracker--achieved" style="margin:14px 0;padding:14px;background:#E8F5E9;border-radius:var(--radius-card);border:1px solid #81C784;">
                <div style="display:flex;align-items:center;gap:8px;font-size:0.9rem;color:#1B5E20;font-weight:600;line-height:1.4;">
                  <span aria-hidden="true" style="font-size:1.15em;">🎉</span>
                  <span>You've unlocked <strong>free shipping</strong>!</span>
                </div>
              </div>
            {%- endif -%}

            <div class="cart-summary__shipping">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4z"/>
              </svg>
              Taxes & shipping at checkout
            </div>

            <a href="{{ routes.checkout }}" class="btn btn--primary btn--full btn--large" style="margin-bottom:10px;">
              Checkout → <span style="font-size:0.85em;opacity:0.85;">{{ cart.total_price | money }} CAD</span>
            </a>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline btn--full">
              Continue Shopping
            </a>
            <div class="cart-summary__trust">
              <span>✦ Secure checkout</span>
              <span>✦ Canadian business</span>
              <span>✦ Satisfaction guaranteed</span>
            </div>
          </div>
        </aside>
      </div>
    {%- else -%}
      <div class="cart-empty">
        <div class="cart-empty__icon">✦</div>
        <h2>Your cart is empty</h2>
        <p class="text-muted">Looks like you haven't added any portraits yet. Your pet deserves to be immortalised!</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--large" style="margin-top:24px;">
          Start Creating
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  /* Replace cart thumbnails with the actual generated portrait from localStorage */
  (function () {
    try {
      var raw = localStorage.getItem('petPrintables_session');
      if (!raw) return;
      var data = JSON.parse(raw);
      if (!data) return;

      // Prefer CDN URLs, then data URLs (base64)
      var cdnUrls = data.previewCdnUrls || [];
      var dataUrls = data.previewDataUrls || [];
      var idx = data.selectedPreviewIndex || 0;
      var portraitSrc = cdnUrls[idx] || cdnUrls[0] || dataUrls[idx] || dataUrls[0];
      if (!portraitSrc) return;

      document.querySelectorAll('.cart-page__item-img img').forEach(function (img) {
        img.src = portraitSrc;
        img.srcset = '';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '8px';

        // If CDN URL fails to load, fall back to base64 data URL
        img.onerror = function () {
          var fallback = dataUrls[idx] || dataUrls[0];
          if (fallback && img.src !== fallback) {
            img.src = fallback;
          }
        };
      });
    } catch (e) {}
  })();

  /* ── Name-on-portrait toggle (cart page) ────────────────────
   * Lets user flip between with-name and no-name versions.
   * Updates line item properties via Shopify Ajax API + live
   * swaps the preview image. Calls /add-name to generate the
   * with-name version if we don't already have it.
   */
  (function () {
    var API_BASE = (window.petPrintables && window.petPrintables.previewApi) || 'https://web-production-a392e.up.railway.app';

    document.querySelectorAll('.cart-page__item').forEach(function (itemEl) {
      var petName = itemEl.dataset.petName;
      var style = itemEl.dataset.style;
      if (!petName) return;

      var buttons = itemEl.querySelectorAll('.cart-name-btn');
      var statusEl = itemEl.querySelector('.cart-name-status');
      var imgEl = itemEl.querySelector('.cart-page__portrait-preview');
      var key = itemEl.getAttribute('data-cart-item');

      function updateButtonStyles(activeValue) {
        buttons.forEach(function (btn) {
          var isActive = btn.dataset.nameValue === activeValue;
          btn.style.background = isActive ? 'var(--color-ink)' : 'transparent';
          btn.style.color = isActive ? '#fff' : 'var(--color-ink)';
          btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      }

      function updateCart(properties) {
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: key, properties: properties }),
        }).then(function (r) { return r.json(); });
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var value = btn.dataset.nameValue;
          var current = itemEl.dataset.showName;
          if (value === current) return;

          // Gather all existing properties so we don't lose them on the update
          var existingProps = {};
          // Shopify's /cart/change.js needs the FULL properties object;
          // read from hidden item data we already stored.
          existingProps['Pet Name'] = petName;
          if (style) existingProps['_Style'] = style;
          if (itemEl.dataset.jobId) existingProps['_Job ID'] = itemEl.dataset.jobId;

          if (value === 'No') {
            // Switch to no-name version
            var noNameUrl = itemEl.dataset.noNameUrl;
            if (!noNameUrl) {
              // Fall back: same as portrait URL (won't actually remove name
              // unless the no-name URL was stored at ATC time)
              noNameUrl = itemEl.dataset.portraitUrl;
            }
            existingProps['_Show Name'] = 'No';
            existingProps['_Portrait URL'] = noNameUrl;
            existingProps['_Print File URL'] = noNameUrl;
            btn.disabled = true;
            updateCart(existingProps).then(function () {
              if (imgEl) imgEl.src = noNameUrl;
              itemEl.dataset.showName = 'No';
              itemEl.dataset.portraitUrl = noNameUrl;
              updateButtonStyles('No');
              btn.disabled = false;
              if (statusEl) { statusEl.textContent = 'Updated'; statusEl.style.display = 'inline'; setTimeout(function(){statusEl.style.display='none';}, 2000); }
            });
          } else {
            // Switch to with-name version — generate on the fly
            var sourceUrl = itemEl.dataset.noNameUrl || itemEl.dataset.portraitUrl;
            if (!sourceUrl) return;

            btn.disabled = true;
            if (statusEl) { statusEl.textContent = 'Adding name…'; statusEl.style.display = 'inline'; }

            fetch(API_BASE + '/add-name', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                image_url: sourceUrl,
                pet_name: petName,
                style: style,
              }),
            })
            .then(function (r) { return r.ok ? r.json() : r.json().then(function (d) { throw new Error(d.error || 'Failed'); }); })
            .then(function (resp) {
              var newUrl = resp.composited || resp.composited_png_cdn;
              existingProps['_Show Name'] = 'Yes';
              existingProps['_Portrait URL'] = newUrl;
              existingProps['_Print File URL'] = resp.composited_png_cdn || newUrl;
              existingProps['_No Name URL'] = sourceUrl;  // preserve for future toggling
              return updateCart(existingProps).then(function () {
                if (imgEl) imgEl.src = newUrl;
                itemEl.dataset.showName = 'Yes';
                itemEl.dataset.portraitUrl = newUrl;
                itemEl.dataset.noNameUrl = sourceUrl;
                updateButtonStyles('Yes');
                btn.disabled = false;
                if (statusEl) { statusEl.textContent = 'Updated'; setTimeout(function(){statusEl.style.display='none';}, 2000); }
              });
            })
            .catch(function (err) {
              btn.disabled = false;
              if (statusEl) { statusEl.textContent = 'Error — ' + (err.message || err); setTimeout(function(){statusEl.style.display='none';}, 3000); }
            });
          }
        });
      });
    });
  })();
</script>

{% schema %}
{ "name": "Cart Items" }
{% endschema %}
