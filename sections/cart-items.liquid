<div class="cart-page">
  <div class="container container--mid">
    {%- render 'breadcrumbs' -%}
    <h1 class="cart-page__title">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      <div class="cart-page__layout">
        <div class="cart-page__items">
          {%- for item in cart.items -%}
            {%- assign portrait_url = nil -%}
            {%- assign no_name_url = nil -%}
            {%- assign show_name = 'Yes' -%}
            {%- assign pet_name_val = '' -%}
            {%- assign style_val = '' -%}
            {%- assign job_id_val = '' -%}
            {%- for property in item.properties -%}
              {%- if property.first == '_Portrait URL' and property.last != blank -%}{%- assign portrait_url = property.last -%}{%- endif -%}
              {%- if property.first == '_No Name URL' and property.last != blank -%}{%- assign no_name_url = property.last -%}{%- endif -%}
              {%- if property.first == '_Show Name' -%}{%- assign show_name = property.last -%}{%- endif -%}
              {%- if property.first == 'Pet Name' -%}{%- assign pet_name_val = property.last -%}{%- endif -%}
              {%- if property.first == '_Style' -%}{%- assign style_val = property.last -%}{%- endif -%}
              {%- if property.first == '_Job ID' -%}{%- assign job_id_val = property.last -%}{%- endif -%}
            {%- endfor -%}
            <div class="cart-page__item"
                 data-cart-item="{{ item.key }}"
                 data-show-name="{{ show_name }}"
                 data-pet-name="{{ pet_name_val | escape }}"
                 data-style="{{ style_val | escape }}"
                 data-job-id="{{ job_id_val | escape }}"
                 data-portrait-url="{{ portrait_url | default: '' | escape }}"
                 data-no-name-url="{{ no_name_url | default: '' | escape }}">
              <div class="cart-page__item-img">
                {%- if portrait_url -%}
                  <img src="{{ portrait_url }}" alt="{{ item.title }}" loading="lazy" class="cart-page__portrait-preview" style="width:100%;border-radius:8px;object-fit:cover;">
                {%- elsif item.image -%}
                  {{- item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title -}}
                {%- endif -%}
              </div>
              <div class="cart-page__item-info">
                <div class="cart-page__item-header">
                  <div>
                    <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p class="cart-page__item-variant text-muted">{{ item.variant.title }}</p>
                    {%- endunless -%}
                    {%- for property in item.properties -%}
                      {%- unless property.last == blank -%}
                        {%- assign prop_first_char = property.first | slice: 0 -%}
                        {%- unless prop_first_char == '_' -%}
                          <p class="cart-page__item-prop text-muted" style="font-size:0.85rem;">
                            {{ property.first }}: {{ property.last }}
                          </p>
                        {%- endunless -%}
                      {%- endunless -%}
                    {%- endfor -%}
                  </div>
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0"
                     class="cart-page__remove" aria-label="Remove {{ item.title | escape }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </a>
                </div>
                {%- if pet_name_val != blank -%}
                <div class="cart-page__name-toggle" style="display:flex;align-items:center;gap:8px;margin:10px 0;font-size:0.85rem;">
                  <span style="color:var(--color-muted);">Name on portrait:</span>
                  <button type="button" class="cart-name-btn" data-name-value="Yes"
                          aria-pressed="{% if show_name == 'Yes' %}true{% else %}false{% endif %}"
                          style="padding:4px 12px;border-radius:14px;border:1px solid var(--color-border);cursor:pointer;font-size:0.82rem;font-weight:500;background:{% if show_name == 'Yes' %}var(--color-ink);color:#fff;{% else %}transparent;color:var(--color-ink);{% endif %}">Yes</button>
                  <button type="button" class="cart-name-btn" data-name-value="No"
                          aria-pressed="{% if show_name == 'No' %}true{% else %}false{% endif %}"
                          style="padding:4px 12px;border-radius:14px;border:1px solid var(--color-border);cursor:pointer;font-size:0.82rem;font-weight:500;background:{% if show_name == 'No' %}var(--color-ink);color:#fff;{% else %}transparent;color:var(--color-ink);{% endif %}">No</button>
                  <span class="cart-name-status" style="color:var(--color-muted);font-size:0.78rem;display:none;"></span>
                </div>
                {%- endif -%}
                <div class="cart-page__item-footer">
                  <div class="cart-qty">
                    <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="cart-qty__btn" aria-label="Decrease quantity">−</a>
                    <span class="cart-qty__num">{{ item.quantity }}</span>
                    <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="cart-qty__btn" aria-label="Increase quantity">+</a>
                  </div>
                  <span class="cart-page__item-price">{{ item.final_line_price | money }} CAD</span>
                </div>
              </div>
            </div>
          {%- endfor -%}

          <!-- Add another portrait CTA -->
          <a href="/pages/create" class="cart-add-another" style="display:flex;align-items:center;justify-content:center;gap:10px;padding:18px;margin-top:12px;border:1.5px dashed var(--color-border);border-radius:var(--radius-card);background:var(--color-surface);text-decoration:none;color:var(--color-ink);font-family:var(--font-body);font-size:0.95rem;font-weight:500;transition:all 0.2s;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m-8-8h16"/>
            </svg>
            <span>Create another portrait for your family</span>
          </a>
        </div>

        <aside class="cart-page__summary">
          <div class="cart-summary">
            <h2 class="cart-summary__title">Order Summary</h2>
            <div class="cart-summary__row">
              <span>Subtotal ({{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %})</span>
              <span>{{ cart.total_price | money }} CAD</span>
            </div>
            {%- if cart.total_discounts > 0 -%}
              <div class="cart-summary__row cart-summary__row--discount">
                <span>Discounts</span>
                <span>−{{ cart.total_discounts | money }}</span>
              </div>
            {%- endif -%}

            {%- comment -%}
              Free shipping threshold tracker
              cart.total_price is in cents — $85 CAD = 8500 cents
            {%- endcomment -%}
            {%- assign free_ship_cents = 8500 -%}
            {%- assign remaining_cents = free_ship_cents | minus: cart.total_price -%}
            {%- if remaining_cents > 0 -%}
              {%- assign progress_pct = cart.total_price | times: 100.0 | divided_by: free_ship_cents -%}
              <div class="free-ship-tracker" style="margin:14px 0;padding:14px;background:var(--color-surface);border-radius:var(--radius-card);border:1px solid var(--color-border);">
                <div style="display:flex;align-items:center;gap:8px;font-size:0.85rem;color:var(--color-ink);margin-bottom:10px;line-height:1.4;">
                  <span aria-hidden="true" style="font-size:1.1em;">🚚</span>
                  <span>You're <strong style="font-weight:700;color:var(--color-primary);">{{ remaining_cents | money }}</strong> away from free shipping</span>
                </div>
                <div style="height:6px;background:var(--color-border);border-radius:99px;overflow:hidden;">
                  <div style="height:100%;width:{{ progress_pct }}%;background:linear-gradient(90deg,var(--color-primary),var(--color-accent));border-radius:99px;transition:width 0.5s ease;"></div>
                </div>
              </div>
            {%- else -%}
              <div class="free-ship-tracker free-ship-tracker--achieved" style="margin:14px 0;padding:14px;background:#E8F5E9;border-radius:var(--radius-card);border:1px solid #81C784;">
                <div style="display:flex;align-items:center;gap:8px;font-size:0.9rem;color:#1B5E20;font-weight:600;line-height:1.4;">
                  <span aria-hidden="true" style="font-size:1.15em;">🎉</span>
                  <span>You've unlocked <strong>free shipping</strong>!</span>
                </div>
              </div>
            {%- endif -%}

            {%- comment -%}
              Priority Order upsell — toggle that adds/removes the
              priority-order line item via AJAX. Product page is not
              linked anywhere; this is add-to-cart only.
            {%- endcomment -%}
            {%- assign priority_in_cart = false -%}
            {%- assign priority_line_key = '' -%}
            {%- for item in cart.items -%}
              {%- if item.product.handle == 'priority-order' -%}
                {%- assign priority_in_cart = true -%}
                {%- assign priority_line_key = item.key -%}
              {%- endif -%}
            {%- endfor -%}

            <div
              class="priority-upsell"
              data-priority-upsell
              data-in-cart="{{ priority_in_cart }}"
              data-line-key="{{ priority_line_key }}"
              style="margin:12px 0;padding:14px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-card);"
            >
              <label style="display:flex;align-items:flex-start;gap:12px;cursor:pointer;font-family:var(--font-body);">
                <input
                  type="checkbox"
                  id="PriorityUpsellToggle"
                  {% if priority_in_cart %}checked{% endif %}
                  style="width:18px;height:18px;margin-top:2px;accent-color:var(--color-primary);flex-shrink:0;"
                >
                <span style="flex:1;line-height:1.45;">
                  <span style="display:flex;align-items:center;gap:6px;font-size:0.95rem;font-weight:600;color:var(--color-ink);">
                    <span aria-hidden="true">⚡</span>
                    Priority Order
                    <span
                      data-priority-price
                      style="margin-left:auto;font-weight:600;color:var(--color-primary);font-size:0.9rem;"
                    ></span>
                  </span>
                  <span style="display:block;font-size:0.82rem;color:var(--color-muted);margin-top:3px;">
                    Skip to the front of the line — yours gets made first
                  </span>
                  <span
                    data-priority-status
                    role="status"
                    aria-live="polite"
                    style="display:none;font-size:0.78rem;color:var(--color-muted);margin-top:4px;"
                  ></span>
                </span>
              </label>
            </div>

            {%- comment -%}
              Shipping estimator — user enters a postal code, we call
              Shopify's /cart/shipping_rates.json (same carrier rates
              the checkout uses). It's an estimate only — discounts and
              final addresses may change the amount at checkout.
            {%- endcomment -%}
            <div class="cart-summary__estimator" data-shipping-estimator style="margin:14px 0;padding:14px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-card);">
              <label for="ShippingEstPostal" style="display:block;font-family:var(--font-body);font-size:0.9rem;font-weight:600;color:var(--color-ink);margin-bottom:8px;">
                Estimate shipping
              </label>
              <div style="display:flex;gap:8px;">
                <input
                  id="ShippingEstPostal"
                  type="text"
                  inputmode="text"
                  autocomplete="postal-code"
                  placeholder="Postal code (e.g. K1A 0B1)"
                  aria-describedby="ShippingEstNote"
                  style="flex:1;min-width:0;padding:9px 12px;border:1px solid var(--color-border);border-radius:8px;font-family:var(--font-body);font-size:0.9rem;background:#fff;color:var(--color-ink);"
                >
                <button
                  type="button"
                  data-shipping-estimate-btn
                  style="padding:9px 16px;border:1px solid var(--color-ink);background:var(--color-ink);color:#fff;border-radius:8px;font-family:var(--font-body);font-size:0.85rem;font-weight:500;cursor:pointer;white-space:nowrap;"
                >
                  Estimate
                </button>
              </div>
              <div
                data-shipping-result
                role="status"
                aria-live="polite"
                style="display:none;margin-top:10px;font-size:0.88rem;line-height:1.45;"
              ></div>
              <p id="ShippingEstNote" style="margin:10px 0 0;font-size:0.75rem;color:var(--color-muted);line-height:1.45;">
                This is an estimate for your reference only. Final shipping is calculated at checkout and may be different.
              </p>
            </div>

            <a href="/checkout" class="btn btn--primary btn--full btn--large" style="margin-bottom:10px;">
              Checkout → <span style="font-size:0.85em;opacity:0.85;">{{ cart.total_price | money }} CAD</span>
            </a>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline btn--full">
              Continue Shopping
            </a>
            <div class="cart-summary__trust">
              <span>✦ Secure checkout</span>
              <span>✦ Canadian business</span>
              <span>✦ Satisfaction guaranteed</span>
            </div>
          </div>
        </aside>
      </div>
    {%- else -%}
      <div class="cart-empty">
        <div class="cart-empty__icon">✦</div>
        <h2>Your cart is empty</h2>
        <p class="text-muted">Looks like you haven't added any portraits yet. Your pet deserves to be immortalised!</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--large" style="margin-top:24px;">
          Start Creating
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  /* Priority Order upsell toggle ────────────────────────────────
     Fetches the priority-order product JSON once to get variant_id +
     price, renders the price, then wires the checkbox to POST to
     /cart/add.js (when checked) or /cart/change.js (when unchecked).
     No link to the product page exists — the JSON endpoint is used
     purely to resolve the variant. */
  (function () {
    var wrap = document.querySelector('[data-priority-upsell]');
    if (!wrap) return;
    var toggle = wrap.querySelector('#PriorityUpsellToggle');
    var priceEl = wrap.querySelector('[data-priority-price]');
    var statusEl = wrap.querySelector('[data-priority-status]');
    if (!toggle) return;

    var variantId = null;
    var pendingRequest = false;

    function formatMoney(cents) {
      try {
        return new Intl.NumberFormat('en-CA', {
          style: 'currency', currency: 'Cart.currency' === 'Cart.currency' ? 'CAD' : 'CAD',
          minimumFractionDigits: 2,
        }).format((cents || 0) / 100);
      } catch (e) {
        return '$' + (((cents || 0) / 100).toFixed(2));
      }
    }

    function setStatus(msg, isError) {
      if (!statusEl) return;
      statusEl.textContent = msg || '';
      statusEl.style.display = msg ? 'block' : 'none';
      statusEl.style.color = isError ? '#B00020' : 'var(--color-muted)';
    }

    function setBusy(busy) {
      pendingRequest = busy;
      toggle.disabled = busy;
      wrap.style.opacity = busy ? '0.65' : '1';
    }

    // Load variant id + price up front
    fetch('/products/priority-order.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { if (!r.ok) throw new Error('NOT_FOUND'); return r.json(); })
      .then(function (p) {
        var v = (p.variants && p.variants[0]) || null;
        if (!v) throw new Error('NO_VARIANT');
        variantId = v.id;
        if (priceEl) priceEl.textContent = '+' + formatMoney(v.price);
      })
      .catch(function () {
        // Product missing or draft — hide the upsell entirely so we
        // don't render a broken-looking toggle in production.
        wrap.style.display = 'none';
      });

    toggle.addEventListener('change', function () {
      if (pendingRequest) return;
      var wantOn = toggle.checked;

      if (wantOn) {
        if (!variantId) {
          toggle.checked = false;
          setStatus('Priority Order is temporarily unavailable.', true);
          return;
        }
        setBusy(true);
        setStatus('Adding priority to your order…');
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 }),
        })
          .then(function (r) { if (!r.ok) throw new Error('ADD_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = false;
            setStatus('Could not add Priority Order. Please try again.', true);
          });
      } else {
        // Remove by line key captured from the server-rendered attribute
        var lineKey = wrap.getAttribute('data-line-key') || '';
        if (!lineKey) { window.location.reload(); return; }
        setBusy(true);
        setStatus('Removing priority…');
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: lineKey, quantity: 0 }),
        })
          .then(function (r) { if (!r.ok) throw new Error('REMOVE_FAILED'); return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () {
            setBusy(false);
            toggle.checked = true;
            setStatus('Could not remove Priority Order. Please try again.', true);
          });
      }
    });
  })();

  /* Shipping estimator ─────────────────────────────────────────
     Calls Shopify's /cart/shipping_rates.json with the entered
     postal code. Same carrier rates as checkout, so the estimate
     is accurate — differences at checkout come from discounts,
     final addresses, or carrier updates. */
  (function () {
    var wrap = document.querySelector('[data-shipping-estimator]');
    if (!wrap) return;
    var input = wrap.querySelector('#ShippingEstPostal');
    var btn = wrap.querySelector('[data-shipping-estimate-btn]');
    var resultEl = wrap.querySelector('[data-shipping-result]');
    if (!input || !btn || !resultEl) return;

    var SHOP_CURRENCY = {{ cart.currency.iso_code | json }};

    function formatMoneyFromDollars(dollarStr) {
      var n = parseFloat(dollarStr);
      if (!isFinite(n)) return dollarStr;
      try {
        return new Intl.NumberFormat('en-CA', {
          style: 'currency', currency: SHOP_CURRENCY || 'CAD',
          minimumFractionDigits: 2,
        }).format(n);
      } catch (e) {
        return '$' + n.toFixed(2);
      }
    }

    function escapeHtml(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function showResult(html, isError) {
      resultEl.innerHTML = html;
      resultEl.style.display = 'block';
      resultEl.style.color = isError ? '#B00020' : 'var(--color-ink)';
    }

    // Guess the country from the postal pattern. CA uses "A1A 1A1",
    // US uses 5 digits (optionally 5-4). Default to Canada.
    function guessCountry(zip) {
      var bare = zip.replace(/\s+/g, '').toUpperCase();
      if (/^[A-Z]\d[A-Z]\d[A-Z]\d$/.test(bare)) return 'Canada';
      if (/^\d{5}(-\d{4})?$/.test(bare)) return 'United States';
      return 'Canada';
    }

    function fetchRates(zip, country) {
      var params = new URLSearchParams();
      params.append('shipping_address[zip]', zip);
      params.append('shipping_address[country]', country);
      return fetch('/cart/shipping_rates.json?' + params.toString(), {
        headers: { 'Accept': 'application/json' },
      }).then(function (r) {
        if (r.status === 422) {
          return r.json().then(function () { throw new Error('INVALID_POSTAL'); })
            .catch(function () { throw new Error('INVALID_POSTAL'); });
        }
        if (!r.ok) throw new Error('REQUEST_FAILED');
        return r.json();
      });
    }

    function runEstimate() {
      var zip = (input.value || '').trim().toUpperCase();
      if (!zip) {
        showResult('Please enter a postal code.', true);
        input.focus();
        return;
      }
      var country = guessCountry(zip);
      btn.disabled = true;
      showResult('Getting an estimate\u2026', false);
      fetchRates(zip, country)
        .then(function (data) {
          btn.disabled = false;
          var rates = (data && data.shipping_rates) || [];
          if (!rates.length) {
            showResult(
              'No shipping options found for <strong>' + escapeHtml(zip) + '</strong>. '
              + 'Double-check the postal code, or see final shipping at checkout.',
              true
            );
            return;
          }
          // Show all rates sorted cheapest → most expensive.
          var sorted = rates.slice().sort(function (a, b) {
            return parseFloat(a.price) - parseFloat(b.price);
          });
          var rows = sorted.map(function (r) {
            var label = escapeHtml(r.presentment_name || r.name || 'Shipping');
            var price = formatMoneyFromDollars(r.price);
            return '<li style="display:flex;justify-content:space-between;gap:12px;padding:3px 0;">'
              + '<span>' + label + '</span>'
              + '<strong>' + escapeHtml(price) + '</strong>'
              + '</li>';
          }).join('');
          showResult(
            '<div style="font-weight:600;margin-bottom:4px;">Estimated shipping to ' + escapeHtml(zip) + ':</div>'
            + '<ul style="list-style:none;margin:0;padding:0;">' + rows + '</ul>',
            false
          );
        })
        .catch(function (err) {
          btn.disabled = false;
          if (err && err.message === 'INVALID_POSTAL') {
            showResult("That postal code didn\u2019t look right. Please check it and try again.", true);
          } else {
            showResult("Couldn\u2019t fetch an estimate right now. You can see shipping at checkout.", true);
          }
        });
    }

    btn.addEventListener('click', runEstimate);
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); runEstimate(); }
    });
  })();

  /* Free-shipping celebration — trigger on cart page load when the
     current cart is over the $85 threshold and this session hasn't
     celebrated yet. theme.js defines window.petPrintables.maybeCelebrateFreeShipping
     and handles session-scoped de-dupe. */
  (function () {
    function fire() {
      var fn = window.petPrintables && window.petPrintables.maybeCelebrateFreeShipping;
      if (typeof fn === 'function') fn({{ cart.total_price }});
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fire);
    } else {
      fire();
    }
  })();

  /* Replace cart thumbnails with the actual generated portrait from localStorage */
  (function () {
    try {
      var raw = localStorage.getItem('petPrintables_session');
      if (!raw) return;
      var data = JSON.parse(raw);
      if (!data) return;

      // Prefer CDN URLs, then data URLs (base64)
      var cdnUrls = data.previewCdnUrls || [];
      var dataUrls = data.previewDataUrls || [];
      var idx = data.selectedPreviewIndex || 0;
      var portraitSrc = cdnUrls[idx] || cdnUrls[0] || dataUrls[idx] || dataUrls[0];
      if (!portraitSrc) return;

      document.querySelectorAll('.cart-page__item-img img').forEach(function (img) {
        img.src = portraitSrc;
        img.srcset = '';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '8px';

        // If CDN URL fails to load, fall back to base64 data URL
        img.onerror = function () {
          var fallback = dataUrls[idx] || dataUrls[0];
          if (fallback && img.src !== fallback) {
            img.src = fallback;
          }
        };
      });
    } catch (e) {}
  })();

  /* ── Name-on-portrait toggle (cart page) ────────────────────
   * Lets user flip between with-name and no-name versions.
   * Updates line item properties via Shopify Ajax API + live
   * swaps the preview image. Calls /add-name to generate the
   * with-name version if we don't already have it.
   */
  (function () {
    var API_BASE = (window.petPrintables && window.petPrintables.previewApi) || 'https://web-production-a392e.up.railway.app';

    document.querySelectorAll('.cart-page__item').forEach(function (itemEl) {
      var petName = itemEl.dataset.petName;
      var style = itemEl.dataset.style;
      if (!petName) return;

      var buttons = itemEl.querySelectorAll('.cart-name-btn');
      var statusEl = itemEl.querySelector('.cart-name-status');
      var imgEl = itemEl.querySelector('.cart-page__portrait-preview');
      var key = itemEl.getAttribute('data-cart-item');

      function updateButtonStyles(activeValue) {
        buttons.forEach(function (btn) {
          var isActive = btn.dataset.nameValue === activeValue;
          btn.style.background = isActive ? 'var(--color-ink)' : 'transparent';
          btn.style.color = isActive ? '#fff' : 'var(--color-ink)';
          btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      }

      function updateCart(properties) {
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: key, properties: properties }),
        }).then(function (r) { return r.json(); });
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var value = btn.dataset.nameValue;
          var current = itemEl.dataset.showName;
          if (value === current) return;

          // Gather all existing properties so we don't lose them on the update
          var existingProps = {};
          // Shopify's /cart/change.js needs the FULL properties object;
          // read from hidden item data we already stored.
          existingProps['Pet Name'] = petName;
          if (style) existingProps['_Style'] = style;
          if (itemEl.dataset.jobId) existingProps['_Job ID'] = itemEl.dataset.jobId;

          if (value === 'No') {
            // Switch to no-name version
            var noNameUrl = itemEl.dataset.noNameUrl;
            if (!noNameUrl) {
              // Fall back: same as portrait URL (won't actually remove name
              // unless the no-name URL was stored at ATC time)
              noNameUrl = itemEl.dataset.portraitUrl;
            }
            existingProps['_Show Name'] = 'No';
            existingProps['_Portrait URL'] = noNameUrl;
            existingProps['_Print File URL'] = noNameUrl;
            btn.disabled = true;
            updateCart(existingProps).then(function () {
              if (imgEl) imgEl.src = noNameUrl;
              itemEl.dataset.showName = 'No';
              itemEl.dataset.portraitUrl = noNameUrl;
              updateButtonStyles('No');
              btn.disabled = false;
              if (statusEl) { statusEl.textContent = 'Updated'; statusEl.style.display = 'inline'; setTimeout(function(){statusEl.style.display='none';}, 2000); }
            });
          } else {
            // Switch to with-name version — generate on the fly
            var sourceUrl = itemEl.dataset.noNameUrl || itemEl.dataset.portraitUrl;
            if (!sourceUrl) return;

            // Inject spinner keyframe once per page
            if (!document.getElementById('cart-addname-spin-kf')) {
              var kf = document.createElement('style');
              kf.id = 'cart-addname-spin-kf';
              kf.textContent = '@keyframes cartAddNameSpin{to{transform:rotate(360deg)}}';
              document.head.appendChild(kf);
            }

            // Disable BOTH toggle buttons and show spinner + progressive copy
            buttons.forEach(function(b){ b.disabled = true; b.style.opacity = '0.6'; b.style.cursor = 'wait'; });
            if (statusEl) {
              statusEl.innerHTML = '<span style="display:inline-flex;align-items:center;gap:8px;">'
                + '<span aria-hidden="true" style="width:12px;height:12px;border:2px solid var(--color-border,#e5e0db);'
                + 'border-top-color:var(--color-primary,#c4903e);border-radius:50%;animation:cartAddNameSpin 0.9s linear infinite;display:inline-block;"></span>'
                + '<span data-addname-cart-label>Adding the name\u2026</span>'
                + '</span>';
              statusEl.style.display = 'inline-flex';
              statusEl.setAttribute('role', 'status');
              statusEl.setAttribute('aria-live', 'polite');
            }

            var PHRASES = ['Adding the name\u2026', 'Painting the letters\u2026', 'Blending it in\u2026', 'Almost done\u2026'];
            var phaseIdx = 0;
            var cycler = setInterval(function () {
              phaseIdx = Math.min(phaseIdx + 1, PHRASES.length - 1);
              var lbl = statusEl && statusEl.querySelector('[data-addname-cart-label]');
              if (lbl) lbl.textContent = PHRASES[phaseIdx];
            }, 3500);

            function finishLoadingUI() {
              clearInterval(cycler);
              buttons.forEach(function(b){ b.disabled = false; b.style.opacity = ''; b.style.cursor = ''; });
            }

            fetch(API_BASE + '/add-name', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                image_url: sourceUrl,
                pet_name: petName,
                style: style,
              }),
            })
            .then(function (r) { return r.ok ? r.json() : r.json().then(function (d) { throw new Error(d.error || 'Failed'); }); })
            .then(function (resp) {
              var newUrl = resp.composited || resp.composited_png_cdn;
              existingProps['_Show Name'] = 'Yes';
              existingProps['_Portrait URL'] = newUrl;
              existingProps['_Print File URL'] = resp.composited_png_cdn || newUrl;
              existingProps['_No Name URL'] = sourceUrl;  // preserve for future toggling
              return updateCart(existingProps).then(function () {
                if (imgEl) imgEl.src = newUrl;
                itemEl.dataset.showName = 'Yes';
                itemEl.dataset.portraitUrl = newUrl;
                itemEl.dataset.noNameUrl = sourceUrl;
                updateButtonStyles('Yes');
                finishLoadingUI();
                if (statusEl) {
                  statusEl.textContent = 'Updated';
                  statusEl.style.display = 'inline';
                  setTimeout(function(){statusEl.style.display='none';}, 2000);
                }
              });
            })
            .catch(function (err) {
              finishLoadingUI();
              if (statusEl) {
                statusEl.textContent = 'Error — ' + (err.message || err);
                statusEl.style.display = 'inline';
                setTimeout(function(){statusEl.style.display='none';}, 3000);
              }
            });
          }
        });
      });
    });
  })();
</script>

{% schema %}
{ "name": "Cart Items" }
{% endschema %}
