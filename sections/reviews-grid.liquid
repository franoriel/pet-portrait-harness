{%- comment -%}
  TODO: DORMANT — do not re-enable until we have real customer reviews.
  Unreferenced in any template as of launch. Defaults include placeholder "4.9" rating.
  To re-wire: add a "reviews-grid" section to a template and replace defaults with real data.
{%- endcomment -%}
<section class="reviews-section section-padding" aria-label="Customer reviews">
  <div class="container">
    <div class="section-header text-center">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Reviews' }}</span>
      <h2>{{ section.settings.heading | default: 'Loved by pet parents across Canada' }}</h2>
      <div class="reviews-aggregate">
        <span class="reviews-aggregate__stars" aria-label="{{ section.settings.avg_rating }} out of 5">
          {%- assign full = section.settings.avg_rating | floor -%}
          {%- for i in (1..full) -%}★{%- endfor -%}
          {%- if full < 5 -%}☆{%- endif -%}
        </span>
        <span class="reviews-aggregate__score">{{ section.settings.avg_rating }}</span>
        <span class="reviews-aggregate__count text-muted">· {{ section.settings.review_count }} reviews</span>
      </div>
    </div>

    <div class="reviews-grid">
      {%- for block in section.blocks -%}
        <article class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars" aria-label="{{ block.settings.rating }} stars">
            {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
          </div>
          <p class="review-card__text">"{{ block.settings.text }}"</p>
          <div class="review-card__footer">
            {%- if block.settings.photo != blank -%}
              <div class="review-card__photo">
                {{- block.settings.photo | image_url: width: 80 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.author | escape
                -}}
              </div>
            {%- endif -%}
            <div>
              <p class="review-card__author">{{ block.settings.author }}</p>
              <p class="review-card__pet text-muted">{{ block.settings.pet_name }}</p>
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by pet parents across Canada" },
    { "type": "text", "id": "avg_rating", "label": "Average rating", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Total review count", "default": "2,400+" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text" },
        { "type": "text", "id": "author", "label": "Customer name", "default": "Sarah M." },
        { "type": "text", "id": "pet_name", "label": "Pet name", "default": "Biscuit" },
        { "type": "image_picker", "id": "photo", "label": "Portrait photo (optional)" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Reviews Grid" }]
}
{% endschema %}
