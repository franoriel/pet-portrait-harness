{%- if section.settings.show_banner -%}
<div class="urgency-banner" role="region" aria-label="Promotion">
  <div class="urgency-banner__inner">
    {%- if section.settings.icon != blank -%}
      <span class="urgency-banner__icon" aria-hidden="true">{{ section.settings.icon }}</span>
    {%- endif -%}
    <span class="urgency-banner__text">{{ section.settings.text }}</span>
    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <a href="{{ section.settings.cta_url }}" class="urgency-banner__cta">{{ section.settings.cta_label }} →</a>
    {%- endif -%}
  </div>
</div>

<style>
  .urgency-banner {
    background: {{ section.settings.bg_color | default: '#1C1C1C' }};
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
    padding: 10px 16px;
    position: relative;
    z-index: 101;
    overflow: hidden;
  }
  .urgency-banner__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }
  .urgency-banner__icon {
    font-size: 1.05rem;
    animation: urgency-pulse 2s ease-in-out infinite;
    display: inline-block;
  }
  .urgency-banner__text strong {
    font-weight: 700;
  }
  .urgency-banner__cta {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
    white-space: nowrap;
  }
  .urgency-banner__cta:hover { opacity: 0.85; }
  @keyframes urgency-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }
  @media (max-width: 480px) {
    .urgency-banner { padding: 8px 12px; }
    .urgency-banner__inner { font-size: 0.78rem; gap: 8px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .urgency-banner__icon { animation: none; }
  }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Urgency Banner",
  "tag": "aside",
  "settings": [
    { "type": "checkbox", "id": "show_banner", "label": "Show banner", "default": true },
    { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "✨" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Banner text",
      "default": "<p><strong>Every portrait is one-of-a-kind</strong> — once it's gone, we can't recreate it</p>"
    },
    { "type": "text", "id": "cta_label", "label": "CTA label (optional)", "default": "Create yours" },
    { "type": "url", "id": "cta_url", "label": "CTA URL", "default": "" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#2F4A35" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "Urgency Banner" }]
}
{% endschema %}
