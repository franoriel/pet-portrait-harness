<section class="final-cta" aria-labelledby="FinalCtaHeading">
  <div class="container--mid container">
    <span class="eyebrow" style="color:var(--color-primary);">{{ section.settings.eyebrow | default: 'Ready?' }}</span>
    <h2 id="FinalCtaHeading">{{ section.settings.heading | default: "The portrait they'll never take down." }}</h2>
    <p>{{ section.settings.subheading | default: "Start with a photo. We'll handle the painting, printing, and shipping." }}</p>
    <div style="display:flex;flex-direction:column;align-items:center;gap:12px;">
      <a href="{{ section.settings.cta_url | default: '/pages/create' }}" class="btn btn--canvas-frame btn--large">
        <span class="btn__canvas-inner">
          {{ section.settings.cta_label | default: 'Create My Portrait' }}
          <svg class="btn__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
      <p style="font-size:var(--text-xs);color:rgba(255,255,255,0.5);">Free preview · Free redos · Printed in Canada · Ships within Canada only</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The portrait they will never take down." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Upload one photo. The preview is free. Pay only if you love it." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Create My Portrait" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Final CTA" }]
}
{% endschema %}
