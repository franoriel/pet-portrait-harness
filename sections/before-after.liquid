<section class="before-after section-padding" aria-labelledby="BeforeAfterHeading">
  <div class="container--mid container text-center">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'The Transformation' }}</span>
    <h2 id="BeforeAfterHeading">{{ section.settings.heading | default: 'Photo to Portrait' }}</h2>
    <p class="text-muted" style="margin-top:8px;max-width:440px;margin-left:auto;margin-right:auto;">
      {{ section.settings.subheading | default: 'Drag the slider to see the before & after. Every portrait is unique to your pet.' }}
    </p>

    <div class="before-after__slider" role="img" aria-label="Before and after comparison of a pet photo transformed into a custom portrait">
      {%- if section.settings.before_image != blank -%}
        {{- section.settings.before_image | image_url: width: 800 | image_tag:
          class: 'before-after__img before-after__before',
          loading: 'lazy',
          alt: 'Original pet photo'
        -}}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'before-after__img before-after__before' }}
      {%- endif -%}

      {%- if section.settings.after_image != blank -%}
        {{- section.settings.after_image | image_url: width: 800 | image_tag:
          class: 'before-after__img before-after__after',
          loading: 'lazy',
          alt: 'Custom portrait of pet'
        -}}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'before-after__img before-after__after' }}
      {%- endif -%}

      <div class="before-after__divider" aria-hidden="true"></div>
      <div class="before-after__handle" aria-hidden="true">⟺</div>
      <span class="before-after__label before-after__label--before">Photo</span>
      <span class="before-after__label before-after__label--after">Portrait</span>
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div style="margin-top:32px;">
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Before / After Slider",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Transformation" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Photo to Portrait" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "image_picker", "id": "before_image", "label": "Before image (original photo)" },
    { "type": "image_picker", "id": "after_image", "label": "After image (portrait)" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Before / After Slider" }]
}
{% endschema %}
