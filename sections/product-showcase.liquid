<section class="product-showcase section-padding" aria-labelledby="ShowcaseHeading">
  <div class="container">
    <div class="text-center" style="margin-bottom:8px;">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Our Products' }}</span>
      <h2 id="ShowcaseHeading">{{ section.settings.heading | default: 'Your Portrait, Your Way' }}</h2>
      <p class="text-muted" style="margin-top:8px;">{{ section.settings.subheading | default: 'Choose how you want to display your custom pet portrait.' }}</p>
    </div>

    <div class="product-showcase__grid" role="list" aria-label="Product categories">
      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product] -%}
        <div class="product-card" role="listitem" data-reveal {{ block.shopify_attributes }}>
          <div class="product-card__img">
            {%- if block.settings.image != blank -%}
              {{- block.settings.image | image_url: width: 480 | image_tag:
                data-lazy: '',
                loading: 'lazy',
                alt: block.settings.title,
                widths: '240, 480',
                sizes: '220px'
              -}}
            {%- elsif product != blank and product.featured_image -%}
              {{- product.featured_image | image_url: width: 480 | image_tag:
                loading: 'lazy',
                alt: product.title,
                widths: '240, 480',
                sizes: '220px'
              -}}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="product-card__body">
            <p class="product-card__title">{{ block.settings.title | default: product.title }}</p>
            <p class="product-card__price">
              {%- if product != blank -%}
                {{ product.price_min | money }} CAD
              {%- else -%}
                {{ block.settings.price | default: 'From $29 CAD' }}
              {%- endif -%}
            </p>
            <a class="product-card__cta" href="{{ block.settings.url | default: product.url }}">
              Shop {{ block.settings.title | default: 'This' }} →
            </a>
          </div>
        </div>
      {%- else -%}
        {%- assign placeholders = 'Print,Mug,Canvas,Tote Bag,Phone Case' | split: ',' -%}
        {%- for p in placeholders -%}
          <div class="product-card" role="listitem">
            <div class="product-card__img">{{ 'product-' | append: forloop.index | placeholder_svg_tag }}</div>
            <div class="product-card__body">
              <p class="product-card__title">{{ p }}</p>
              <p class="product-card__price">From $29 CAD</p>
              <span class="product-card__cta">Shop {{ p }} →</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Portrait, Your Way" },
    { "type": "text", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Override image" },
        { "type": "text", "id": "title", "label": "Override title" },
        { "type": "text", "id": "price", "label": "Override price", "default": "From $29 CAD" },
        { "type": "url", "id": "url", "label": "Override URL" }
      ]
    }
  ],
  "presets": [{ "name": "Product Showcase" }]
}
{% endschema %}
