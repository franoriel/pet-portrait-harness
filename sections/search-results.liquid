<div class="search-page section-padding">
  <div class="container">
    <header class="section-header text-center" style="margin-bottom:32px;">
      <h1>Search</h1>
    </header>

    <div class="search-page__bar">
      {%- form 'search' -%}
        <div class="search-bar search-bar--large">
          <input type="search" name="q" value="{{ search.terms | escape }}"
            placeholder="Search portraits, products…" class="search-bar__input" autocomplete="off" autofocus>
          <button type="submit" class="search-bar__btn btn btn--primary" aria-label="Search">Search</button>
        </div>
      {%- endform -%}
    </div>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <div class="search-empty text-center" style="padding:48px 0;">
          <p aria-hidden="true" style="font-size:2rem;margin-bottom:12px;color:var(--color-muted);">✦</p>
          <h2>No results for "{{ search.terms | escape }}"</h2>
          <p class="text-muted">Try a different search, or browse all our products below.</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" style="margin-top:20px;">Browse All Portraits</a>
        </div>
      {%- else -%}
        <p class="search-count text-muted" style="margin-bottom:24px;">
          {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for
          "<strong>{{ search.terms | escape }}</strong>"
        </p>
        {%- paginate search.results by 16 -%}
          <div class="collection-grid">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {%- render 'product-card', product: item -%}
              {%- else -%}
                <article class="article-card article-card--compact">
                  <div class="article-card__body">
                    <p class="article-card__meta text-muted" style="text-transform:capitalize;">{{ item.object_type }}</p>
                    <h3 class="article-card__title" style="font-size:1rem;">
                      <a href="{{ item.url }}">{{ item.title }}</a>
                    </h3>
                    <p class="text-muted" style="font-size:0.85rem;">{{ item.content | strip_html | truncate: 100 }}</p>
                  </div>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- render 'pagination', paginate: paginate -%}
        {%- endpaginate -%}
      {%- endif -%}
    {%- endif -%}
  </div>
</div>
{% schema %}{ "name": "Search Results" }{% endschema %}
