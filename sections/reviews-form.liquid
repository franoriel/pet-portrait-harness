{%- comment -%}
  Pre-launch reviews collection page. Linked from the Flask /portraits/<token>
  page (the digital-gift landing page) and from the post-purchase email's
  review CTA. Not yet linked from main nav. Set robots:noindex so it doesn't
  show up in search until we're ready. Submissions go through Shopify's
  built-in {% form 'contact' %} so they land in the store's notification
  email. Switch the form action to Judge.me's submit endpoint later if/when
  we want them flowing into Judge.me directly.
{%- endcomment -%}

<meta name="robots" content="noindex,nofollow">

<div class="reviews-page section-padding">
  <div class="container container--narrow">
    <div class="section-header text-center">
      <span class="eyebrow">A favour to ask</span>
      <h1>{{ page.title | default: 'How was your portrait?' }}</h1>
      <p class="text-muted" style="max-width:520px;margin:0 auto;">
        Your review helps another pet parent decide whether to make one for their dog.
        Share what worked, what didn't, and a photo of the canvas in your home if you have one.
      </p>
    </div>

    <div class="reviews-form-wrap" style="max-width:560px;margin:48px auto 0;">
      {%- form 'contact', id: 'ReviewForm' -%}
        {%- if form.posted_successfully? -%}
          <div class="form-success" role="status" style="text-align:center;padding:32px;background:#F3EDE6;border-radius:12px;">
            <span style="font-size:2rem;display:block;margin-bottom:8px;">✦</span>
            <h2 style="font-family:var(--font-heading-family,'Cormorant Garamond',serif);font-style:italic;font-weight:500;font-size:1.6rem;margin:0 0 8px;">Thank you.</h2>
            <p style="margin:0;color:var(--color-muted,#6B6B63);">We read every word. If your review goes public, we'll let you know.</p>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="form-errors" role="alert">
            <p>Please fix the following:</p>
            <ul>
              {%- for field in form.errors -%}
                <li>{{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <input type="hidden" name="contact[subject]" value="Review submission">

        <div class="form-field">
          <label class="form-label">Your rating</label>
          <div class="star-rating" role="radiogroup" aria-label="Star rating">
            {%- for i in (1..5) reversed -%}
              <input type="radio" id="ReviewStar{{ i }}" name="contact[rating]" value="{{ i }}"{% if i == 5 %} required{% endif %}>
              <label for="ReviewStar{{ i }}" aria-label="{{ i }} star{% if i != 1 %}s{% endif %}">★</label>
            {%- endfor -%}
          </div>
        </div>

        <div class="form-field">
          <label class="form-label" for="ReviewOrder">Order number</label>
          <input type="text" id="ReviewOrder" name="contact[order_number]"
            class="form-input" placeholder="#1042" autocomplete="off">
        </div>

        <div class="form-field">
          <label class="form-label" for="ReviewName">Your name</label>
          <input type="text" id="ReviewName" name="contact[name]"
            value="{{ form.name }}" autocomplete="name" required
            class="form-input" placeholder="Jane Smith">
        </div>

        <div class="form-field">
          <label class="form-label" for="ReviewEmail">Email</label>
          <input type="email" id="ReviewEmail" name="contact[email]"
            value="{{ form.email }}" autocomplete="email" required
            class="form-input" placeholder="jane@example.com">
        </div>

        <div class="form-field">
          <label class="form-label" for="ReviewPet">Pet's name <span class="text-muted" style="font-weight:400;">(optional)</span></label>
          <input type="text" id="ReviewPet" name="contact[pet_name]"
            class="form-input" placeholder="Luna">
        </div>

        <div class="form-field">
          <label class="form-label" for="ReviewBody">What did you think?</label>
          <textarea id="ReviewBody" name="contact[body]" rows="6"
            class="form-input" placeholder="What you loved, what surprised you, what we could do better." required>{{ form.body }}</textarea>
        </div>

        <div class="form-field">
          <label class="form-label">
            <input type="checkbox" name="contact[publish_consent]" value="yes" style="margin-right:8px;vertical-align:middle;">
            You can publish my review on the site (with first name only).
          </label>
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--large">
          Send Review →
        </button>
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .reviews-page .star-rating { display:inline-flex; flex-direction:row-reverse; gap:4px; margin-top:6px; }
  .reviews-page .star-rating input { position:absolute; opacity:0; pointer-events:none; }
  .reviews-page .star-rating label { font-size:32px; color:#D9D2C7; cursor:pointer; line-height:1; transition:color 0.15s; }
  .reviews-page .star-rating input:checked ~ label,
  .reviews-page .star-rating label:hover,
  .reviews-page .star-rating label:hover ~ label { color:#C77B58; }
  .reviews-page .star-rating input:focus-visible + label { outline:2px solid #1C1C1C; outline-offset:2px; }
</style>

{% schema %}{ "name": "Reviews Form" }{% endschema %}
