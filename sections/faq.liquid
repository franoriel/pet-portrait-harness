<section class="faq section-padding" aria-labelledby="FaqHeading">
  <div class="container--narrow container">
    <div class="text-center" style="margin-bottom:8px;">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Questions' }}</span>
      <h2 id="FaqHeading">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
    </div>

    <div class="faq__list" role="list">
      {%- for block in section.blocks -%}
        <div class="faq__item" role="listitem" {{ block.shopify_attributes }}>
          <button
            class="faq__question"
            aria-expanded="false"
            aria-controls="FaqAnswer-{{ block.id }}"
            id="FaqQuestion-{{ block.id }}"
          >
            {{ block.settings.question }}
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            class="faq__answer"
            id="FaqAnswer-{{ block.id }}"
            role="region"
            aria-labelledby="FaqQuestion-{{ block.id }}"
          >
            {{ block.settings.answer }}
          </div>
        </div>
      {%- else -%}
        {%- assign default_faqs = "How long until I see my portrait?|About moments after you upload. You get the full preview before you spend a cent — if you don't love it, you walk away.;What kind of photo should I use?|A clear shot where you can see your pet's face. Front-facing and decent lighting help, but phone photos from your camera roll usually work perfectly.;What if I don't love how it turns out?|Contact us and we'll work it out. Our team is fair and works its hardest to make sure you're happy with what arrives.;Where do you ship?|Canada only for now — US shipping is on the way. Most orders produce and ship within a few business days, and you'll get tracking by email once it's on its way.;How do I hang it?|Every canvas arrives with the hanging hardware already installed on the back — a single nail or screw in the wall is all you need (use a drywall anchor for sizes 16x20 and up). Hang the centre at eye level — about 57-60 inches off the floor — and keep it out of direct sunlight and humid spots so the colours and canvas stay perfect. Posters ship flat in a protective sleeve so you can frame them however you like.;Can I order more than one?|Yes — come back and create a new portrait for each pet. A lot of customers do a set for the whole family." | split: ";" -%}
        {%- for faq in default_faqs -%}
          {%- assign parts = faq | split: '|' -%}
          <div class="faq__item" role="listitem">
            <button class="faq__question" aria-expanded="false">
              {{ parts[0] }}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq__answer">{{ parts[1] }}</div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Questions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
