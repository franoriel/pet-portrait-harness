<section class="faq section-padding" aria-labelledby="FaqHeading">
  <div class="container--narrow container">
    <div class="text-center" style="margin-bottom:8px;">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Questions' }}</span>
      <h2 id="FaqHeading">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
    </div>

    <div class="faq__list" role="list">
      {%- for block in section.blocks -%}
        <div class="faq__item" role="listitem" {{ block.shopify_attributes }}>
          <button
            class="faq__question"
            aria-expanded="false"
            aria-controls="FaqAnswer-{{ block.id }}"
            id="FaqQuestion-{{ block.id }}"
          >
            {{ block.settings.question }}
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            class="faq__answer"
            id="FaqAnswer-{{ block.id }}"
            role="region"
            aria-labelledby="FaqQuestion-{{ block.id }}"
          >
            {{ block.settings.answer }}
          </div>
        </div>
      {%- else -%}
        {%- assign default_faqs = "How long until I see my portrait?|About moments after you upload your photo. Seriously. You get a full preview before you pay a cent.;What kind of photo should I use?|A clear shot where you can see your pet's face. Front-facing and decent lighting help, but phone photos from your camera roll usually work perfectly.;Can I order one for a pet who has passed away?|Of course. A lot of our orders are memorial pieces, and we treat every one with care. Send us the best photo you have and we will do the rest.;What if I do not love how it turns out?|We will redo it for free. If you are still not happy after that, full refund — no questions, no hassle.;Where do you ship?|Canada and the US. We aim to turn around quickly — most orders produce and ship within about a week. You will get tracking by email.;Can I order more than one?|Yes — you can come back and create a new portrait for each pet. A lot of customers do a set for the whole family." | split: ";" -%}
        {%- for faq in default_faqs -%}
          {%- assign parts = faq | split: '|' -%}
          <div class="faq__item" role="listitem">
            <button class="faq__question" aria-expanded="false">
              {{ parts[0] }}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq__answer">{{ parts[1] }}</div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Questions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
