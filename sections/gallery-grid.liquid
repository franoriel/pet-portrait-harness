<section class="gallery-page" aria-labelledby="GalleryHeading">
  <div class="container">
    <div class="text-center" style="margin-bottom:32px;">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Our Work' }}</span>
      <h1 id="GalleryHeading">{{ section.settings.heading | default: 'Portrait Gallery' }}</h1>
      <p class="text-muted" style="margin-top:8px;">{{ section.settings.subheading | default: 'Every portrait is as unique as the pet it celebrates.' }}</p>
    </div>

    <!-- Filter bar -->
    <div class="gallery-filter" role="group" aria-label="Filter gallery by pet type">
      <button class="filter-btn is-active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="dogs">Dogs</button>
      <button class="filter-btn" data-filter="cats">Cats</button>
      <button class="filter-btn" data-filter="other">Other</button>
    </div>

    {%- comment -%}
      Customer submissions live in the `gallery_submission` metaobject type
      and are populated automatically when a customer clicks "Submit to
      Gallery" in their digital-gift email. Sorted newest-first so a fresh
      submission shows above older ones; rendered alongside curated blocks.
    {%- endcomment -%}
    {%- assign submissions = shop.metaobjects.gallery_submission.values | sort: 'submitted_at' | reverse -%}

    <div class="gallery-grid" role="list" aria-label="Pet portrait gallery">
      {%- for block in section.blocks -%}
        <div
          class="gallery-item"
          role="listitem"
          data-category="{{ block.settings.category }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{- block.settings.image | image_url: width: 600 | image_tag:
              loading: 'lazy',
              alt: block.settings.caption | default: 'Pet portrait',
              widths: '300, 600',
              sizes: '(min-width:1024px) 33vw, 50vw'
            -}}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag }}
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <p style="font-size:0.78rem;color:var(--color-muted);padding:6px 8px;text-align:center;">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}

      {%- for sub in submissions -%}
        {%- if sub.image != blank -%}
          <div
            class="gallery-item"
            role="listitem"
            data-category="{{ sub.category | default: 'dogs' }}"
          >
            {{- sub.image | image_url: width: 600 | image_tag:
              loading: 'lazy',
              alt: sub.pet_name | default: 'Customer pet portrait',
              widths: '300, 600',
              sizes: '(min-width:1024px) 33vw, 50vw'
            -}}
            {%- if sub.pet_name != blank -%}
              <p style="font-size:0.78rem;color:var(--color-muted);padding:6px 8px;text-align:center;">{{ sub.pet_name }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.blocks.size == 0 and submissions.size == 0 -%}
        {%- comment -%}
          Default gallery fills with the 8 style example assets shipped in
          assets/example-*.webp (the same images that power the homepage
          marquee). Replaced as soon as a merchant adds custom Gallery Item
          blocks via the theme editor.

          Categories are illustrative ("dogs" by default since the shipped
          examples are dog-led) — when real customer pieces are added as
          blocks, set the appropriate category there.
        {%- endcomment -%}
        {%- assign default_examples = "soft-watercolour|Soft Watercolour;minimal-line-art|Minimal Line Art;modern-shape-art|Modern;charcoal|Charcoal;neon-pop-art|Neon Pop Art;renaissance-royalty|Renaissance Royalty;bold-graphic-poster|Bold Graphic Poster;aura-gradient|Aura Gradient" | split: ";" -%}
        {%- for entry in default_examples -%}
          {%- assign parts = entry | split: '|' -%}
          {%- assign slug = parts[0] -%}
          {%- assign label = parts[1] -%}
          {%- comment -%}
            Modern style ships under a -v2 filename to bust browser
            caches that pinned the original (which had stray shape
            accents). The -v2 asset is the rewritten clean version.
          {%- endcomment -%}
          {%- assign asset_name = 'example-' | append: slug | append: '.webp' -%}
          {%- if slug == 'modern-shape-art' -%}
            {%- assign asset_name = 'example-modern-shape-art-v2.webp' -%}
          {%- endif -%}
          <div class="gallery-item" role="listitem" data-category="dogs">
            <img
              src="{{ asset_name | asset_url }}"
              alt="{{ label }} style example portrait"
              loading="lazy"
              width="200"
              height="248"
              style="width:100%;height:auto;display:block;border-radius:var(--radius-card);"
            >
            <p style="font-size:0.78rem;color:var(--color-muted);padding:6px 8px;text-align:center;">{{ label }}</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="text-center" style="margin-top:48px;">
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary btn--large">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gallery Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Work" },
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Portrait Gallery" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "blocks": [
    {
      "type": "gallery_item",
      "name": "Gallery Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Portrait image" },
        { "type": "text", "id": "caption", "label": "Caption (pet name)", "default": "Biscuit the Golden" },
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "options": [
            { "value": "dogs", "label": "Dogs" },
            { "value": "cats", "label": "Cats" },
            { "value": "other", "label": "Other" }
          ],
          "default": "dogs"
        }
      ]
    }
  ],
  "presets": [{ "name": "Gallery Grid" }]
}
{% endschema %}
