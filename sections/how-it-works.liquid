{%- comment -%}
  Layout resolution order:
  1. Explicit section setting (when the editor/schema picks it up)
  2. `template` string (e.g. "page.how-it-works") or current page handle —
     the dedicated How It Works page stacks vertically
  3. Fall back to horizontal (used on the homepage card layout)
{%- endcomment -%}
{%- assign hiw_layout = section.settings.layout -%}
{%- if hiw_layout == blank -%}
  {%- assign _tpl = template | append: '' -%}
  {%- if _tpl contains 'how-it-works' or page.handle == 'how-it-works' -%}
    {%- assign hiw_layout = 'vertical' -%}
  {%- else -%}
    {%- assign hiw_layout = 'horizontal' -%}
  {%- endif -%}
{%- endif -%}
<section class="hiw hiw--{{ hiw_layout }} section-padding" aria-labelledby="HiwHeading">
  <div class="container text-center">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'Simple Process' }}</span>
    <h2 id="HiwHeading">{{ section.settings.heading | default: 'The Transformation' }}</h2>
    <p class="text-muted" style="margin-top:10px;max-width:480px;margin-left:auto;margin-right:auto;">
      {{ section.settings.subheading | default: 'From photo to art.' }}
    </p>

    {%- comment -%}
      Step media — three hyper-real lifestyle photographs map to the
      three step blocks by index. They live as theme assets so the
      sequence stays consistent without per-block image-picker setup.
      Each card gets a slow Ken Burns scale (different delays per card)
      so the trio feels animated without three competing motions.
    {%- endcomment -%}
    {%- assign hiw_step_media = 'hiw-step-1-upload.webp,hiw-step-2-preview.webp,hiw-step-3-ship.webp' | split: ',' -%}
    {%- assign hiw_step_alt = 'A phone displaying a pet photo, fingertip about to tap to upload,A tablet showing a finished watercolour pet portrait at home,Hands lifting a finished pet portrait canvas out of its shipping box' | split: ',' -%}

    <div class="hiw__steps" role="list">
      {%- for block in section.blocks -%}
        <div class="hiw__step hiw__step--media" role="listitem" data-reveal {{ block.shopify_attributes }}>
          {%- assign _media = hiw_step_media[forloop.index0] -%}
          {%- assign _alt = hiw_step_alt[forloop.index0] -%}
          {%- if _media != blank -%}
            <div class="hiw__step-media" aria-hidden="true">
              <img src="{{ _media | asset_url }}" alt="{{ _alt }}" loading="lazy" width="1280" height="956">
            </div>
          {%- endif -%}
          <div class="hiw__step-num" aria-label="Step {{ forloop.index }}">{{ forloop.index }}</div>
          <div class="hiw__step-body">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        </div>
      {%- else -%}
        <div class="hiw__step hiw__step--media" role="listitem">
          <div class="hiw__step-media" aria-hidden="true">
            <img src="{{ 'hiw-step-1-upload.webp' | asset_url }}" alt="A phone displaying a pet photo" loading="lazy" width="1280" height="956">
          </div>
          <div class="hiw__step-num">1</div>
          <div class="hiw__step-body">
            <h3>Upload your photo</h3>
            <p>Any clear photo from your camera roll works. A front-facing shot with good lighting gets the best result.</p>
          </div>
        </div>
        <div class="hiw__step hiw__step--media" role="listitem">
          <div class="hiw__step-media" aria-hidden="true">
            <img src="{{ 'hiw-step-2-preview.webp' | asset_url }}" alt="A tablet showing a watercolour pet portrait" loading="lazy" width="1280" height="956">
          </div>
          <div class="hiw__step-num">2</div>
          <div class="hiw__step-body">
            <h3>Preview your portrait</h3>
            <p>Watch your pet transform into a custom portrait in quickly. See it before you commit to anything.</p>
          </div>
        </div>
        <div class="hiw__step hiw__step--media" role="listitem">
          <div class="hiw__step-media" aria-hidden="true">
            <img src="{{ 'hiw-step-3-ship.webp' | asset_url }}" alt="A pet portrait canvas being unboxed" loading="lazy" width="1280" height="956">
          </div>
          <div class="hiw__step-num">3</div>
          <div class="hiw__step-body">
            <h3>We print and ship</h3>
            <p>Choose your canvas size, check out, and your portrait ships in 1–2 business days, ready to hang.</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%}
      CTA intentionally removed. The page-wide sticky "Begin the Process" bar
      handles the conversion ask — duplicating it here was creating CTA noise
      on every section and pulling attention away from the hero CTA + sticky.
    {%- endcomment -%}
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Simple Process" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Transformation" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "horizontal", "label": "Horizontal cards (scrolls on mobile)" },
        { "value": "vertical",   "label": "Vertical timeline (stacked)" }
      ],
      "default": "horizontal"
    },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "icon", "label": "Step icon or number", "default": "1" },
        { "type": "text", "id": "title", "label": "Title", "default": "Upload Your Photo" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Share a clear photo of your beloved pet." }
      ]
    }
  ],
  "presets": [{ "name": "How It Works" }]
}
{% endschema %}
