{% if section.settings.show_bar %}
<div class="announcement-bar" role="region" aria-label="Announcement">
  <p>
    {%- if section.settings.text != blank -%}
      {{ section.settings.text }}
    {%- else -%}
      🚚 Free shipping on orders over $95 CAD &nbsp;|&nbsp;
      <a href="{{ section.settings.link }}">Shop Now →</a>
    {%- endif -%}
  </p>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show announcement bar", "default": true },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Free shipping on orders over $95 CAD — printed in North America</p>" },
    { "type": "url", "id": "link", "label": "Link URL" }
  ]
}
{% endschema %}
