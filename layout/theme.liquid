<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height">
  <meta name="theme-color" content="#2F2F2A">
  <title>{{ page_title }}{% unless page_title == shop.name %} – {{ shop.name }}{% endunless %}</title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://unpkg.com" crossorigin>
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,400&family=Inter:wght@400;500;600&family=Kalam:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Open Graph + Twitter cards for the contest funnel.
    When a FB Share button in a Klaviyo email links to /pages/free-pet-portrait
    (with a ?ref= referral code appended), Facebook scrapes these tags to
    build the link preview. Without them the preview is blank or generic.
    Restricted to the share-pet + share page templates so it doesn't
    pollute other pages' page-level OG that Shopify already emits.
  {%- endcomment -%}
  {%- if template == 'page.share-pet' or template == 'page.share' -%}
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Pet Printables">
    <meta property="og:title" content="Free pet portrait + canvas giveaway · Pet Printables">
    <meta property="og:description" content="Upload one photo. Get a free portrait of your pet. Enter to win the canvas version. Made in Canada.">
    <meta property="og:image" content="https:{{ 'example-soft-watercolour.webp' | asset_url }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Free pet portrait + canvas giveaway">
    <meta name="twitter:description" content="Upload one photo. Get a free portrait of your pet. Enter to win the canvas version.">
    <meta name="twitter:image" content="https:{{ 'example-soft-watercolour.webp' | asset_url }}">
  {%- endif -%}

  <script>
    window.petPrintables = {
      moneyFormat: {{ shop.money_format | json }},
      shopCurrency: "CAD",
      cartUrl: "{{ routes.cart_url }}",
      previewApi: "{{ settings.portrait_api_url | default: 'https://web-production-a392e.up.railway.app' }}",
      turnstileSiteKey: "{{ settings.turnstile_site_key }}",
      klaviyo: {
        publicKey: "{{ settings.klaviyo_public_key | default: 'SPKeMf' }}",
        listId:    "{{ settings.klaviyo_list_id    | default: 'VySGe8' }}"
      }
    };
  </script>

  {%- comment -%} Google Analytics 4 (gtag.js) — storefront pageviews only.
    Shopify's hosted checkout runs on a separate domain, so this tag does
    NOT fire during /checkout. For full purchase/conversion tracking,
    enable the "Google & YouTube" Shopify sales channel and paste the
    same Measurement ID in there. The Measurement ID can be overridden
    via theme settings (settings.ga4_measurement_id); falls back to the
    hardcoded ID below if unset.
  {%- endcomment -%}
  {%- assign ga4_id = settings.ga4_measurement_id | default: 'G-7JB4WNCP8Q' -%}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga4_id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', {{ ga4_id | json }});
  </script>

  {%- comment -%} Meta Pixel — installed and initialised by the official
    "Facebook & Instagram" Shopify sales channel app. We do NOT inject
    fbq() ourselves here: doing so would double-fire PageView and create
    duplicate Pixel IDs. The window.pp_track() helper below just rides
    on whatever fbq() the app exposes, so as long as the sales channel
    is connected our funnel events (Lead / CompleteRegistration / Share /
    custom) flow through the same pixel as PageView.
  {%- endcomment -%}

  {%- comment -%} Funnel telemetry helper — one entry point that fans out
    to GA4 (gtag) and the Meta Pixel that the Shopify Meta sales channel
    has already injected. Sections call window.pp_track(name, props).
    Standard Meta events (PageView/Lead/CompleteRegistration/Share/etc.)
    are sent via track(); anything else goes through trackCustom().
    No-op for fbq when the sales channel app is disconnected.
  {%- endcomment -%}
  <script>
    (function () {
      var META_STD = {
        PageView:1, ViewContent:1, Lead:1, CompleteRegistration:1,
        AddToWishlist:1, InitiateCheckout:1, AddToCart:1, Purchase:1,
        Search:1, Contact:1, Subscribe:1, StartTrial:1
      };
      window.pp_track = function (name, props) {
        props = props || {};
        try { if (window.gtag) gtag('event', name, props); } catch (e) {}
        try {
          if (window.fbq) {
            if (META_STD[name]) fbq('track', name, props);
            else fbq('trackCustom', name, props);
          }
        } catch (e) {}
        try { (window.dataLayer = window.dataLayer || []).push(Object.assign({event:name}, props)); } catch (e) {}
      };
    })();
  </script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- if settings.urgency_banner_show and template.name != 'index' -%}
    <aside class="urgency-banner" role="region" aria-label="Promotion"
           style="--urgency-bg: {{ settings.urgency_banner_bg | default: '#2F4A35' }}; --urgency-fg: {{ settings.urgency_banner_fg | default: '#FFFFFF' }};">
      <div class="urgency-banner__inner">
        {%- if settings.urgency_banner_icon != blank -%}
          <span class="urgency-banner__icon" aria-hidden="true">{{ settings.urgency_banner_icon }}</span>
        {%- endif -%}
        <span class="urgency-banner__text">{{ settings.urgency_banner_text }}</span>
        {%- if settings.urgency_banner_cta_label != blank and settings.urgency_banner_cta_url != blank -%}
          <a href="{{ settings.urgency_banner_cta_url }}" class="urgency-banner__cta">{{ settings.urgency_banner_cta_label }} →</a>
        {%- endif -%}
      </div>
    </aside>
  {%- endif -%}
  {%- section 'announcement-bar' -%}
  <div class="site-frame">
    {%- section 'header' -%}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
  </div>

  {%- section 'footer' -%}

  <!-- ── Sticky mobile CTA bar ──────────────────────────────── -->
  {%- if template.name == 'index' or template.name == 'product' -%}
    <div class="sticky-cta-bar" id="StickyCta" aria-hidden="true">
      {%- if template.name == 'product' -%}
        {%- comment -%}
          Product PDP keeps the dark-fill primary button — it has a price chip
          inline that needs the simpler container.
        {%- endcomment -%}
        <button class="sticky-cta-bar__btn btn btn--primary" id="StickyAddToCart">
          Add to Cart — <span id="StickyPrice"></span>
        </button>
      {%- else -%}
        {%- comment -%}
          Homepage sticky CTA mirrors the hero's framed-canvas button so the
          conversion ask reads as the same brand object in two places. The
          `sticky-cta-bar__btn--pulse` modifier adds a slow ambient pulse
          (2.6s ease-in-out) so the bar still asks for attention without
          flashing aggressively.
        {%- endcomment -%}
        <a href="/pages/create"
           class="sticky-cta-bar__btn sticky-cta-bar__btn--pulse btn btn--canvas-frame btn--large"
           style="text-decoration:none;">
          <span class="btn__canvas-inner">
            Begin the process
            <svg class="btn__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- ── Cart Drawer ─────────────────────────────────────────── -->
  <div id="CartDrawer" class="cart-drawer" role="dialog" aria-modal="true" aria-label="Shopping cart">
    <div class="cart-drawer__overlay" data-cart-overlay></div>
    <div class="cart-drawer__panel">
      <div class="cart-drawer__header">
        <h2 class="cart-drawer__title">Your Cart</h2>
        <button class="cart-drawer__close" data-cart-close aria-label="Close cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="cart-drawer__body" data-cart-body></div>
      <div class="cart-drawer__footer" data-cart-footer></div>
    </div>
  </div>

  <!-- Legacy PortraitModal removed — replaced by React portrait-flow widget -->

  <!-- EXIT INTENT PLACEHOLDER: inject exit popup trigger here -->

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
